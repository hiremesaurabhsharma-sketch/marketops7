---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us | MarketOps" description="Get in touch with MarketOps scaling growth experts. Book a performance ad strategy audit, consult on agency ad accounts, media buying, or custom UGC content operations.">
  <!-- HERO SECTION -->
  <section class="hero-wrapper" style="min-height: 50vh; padding-top: 10rem;">
    <div class="container" style="position: relative; z-index: 1; text-align: center;">
      <div class="reveal-on-scroll">
        <div class="badge-lead">Direct Contact Channels</div>
        <h1 class="gradient-text" style="font-size: clamp(2.2rem, 6vw, 4.5rem); max-width: 900px; margin: 0 auto 1.5rem; text-transform: capitalize;">
          Let's Scale Your <span class="gradient-text-alt" style="font-weight: 800;">Paid Ads</span>
        </h1>
        <p style="font-size: clamp(1rem, 2.5vw, 1.25rem); color: var(--color-text-muted); max-width: 600px; margin: 0 auto;">
          Contact our team 24/7/365 to configure solid ad accounts, optimize media budgets, or test converting UGC hooks.
        </p>
      </div>
    </div>
  </section>

  <!-- CONTACT SPLIT SECTION -->
  <section class="section-padding" style="background: var(--bg-main); border-top: 1px solid var(--border-light); position: relative; overflow: hidden;">
    <!-- Background Glows -->
    <div style="position: absolute; top: -10%; left: -10%; width: 40vw; height: 40vw; background: radial-gradient(circle, rgba(0, 198, 255, 0.05) 0%, transparent 70%); pointer-events: none;"></div>
    <div style="position: absolute; bottom: -10%; right: -10%; width: 40vw; height: 40vw; background: radial-gradient(circle, rgba(255, 63, 108, 0.05) 0%, transparent 70%); pointer-events: none;"></div>

    <div class="container">
      <div class="contact-split-wrapper">
        

        <!-- Right Column: Info Grid -->
        <div class="contact-info-panel reveal-on-scroll">
          <h2 class="info-title">Don't hesitate to reach out to us</h2>
          <p class="info-subtitle">Every feature is built to eliminate risk, remove friction, and help you scale predictably.</p>
          
          <div class="info-grid-2x2">
            <!-- Office Card -->
            <div class="info-glass-card">
              <div class="info-icon" style="color: #00c6ff;">
                <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              </div>
              <div class="info-content">
                <h4>Office</h4>
                <p>1507 Lampman Ct, Cheyenne, WY 82007, United States</p>
                <div class="progress-bar-mock"><div class="progress-fill" style="width: 40%; background: #00c6ff;"></div></div>
              </div>
            </div>

            <!-- Working Hours Card -->
            <div class="info-glass-card">
              <div class="info-icon" style="color: #ffb800;">
                <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
              </div>
              <div class="info-content">
                <h4>Working Hours</h4>
                <p>24 × 7 × 365<br>Always Active</p>
              </div>
            </div>

            <!-- WhatsApp Card -->
            <div class="info-glass-card">
              <div class="info-icon" style="color: #00ffa3;">
                <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"></path></svg>
              </div>
              <div class="info-content">
                <h4>WhatsApp</h4>
                <p><a href="https://wa.me/919424995426" target="_blank" style="color: inherit; text-decoration: none;">+91 94249 95426</a></p>
              </div>
            </div>

            <!-- Email Card -->
            <div class="info-glass-card">
              <div class="info-icon" style="color: #ff3f6c;">
                <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              </div>
              <div class="info-content">
                <h4>Email</h4>
                <p><a href="mailto:connect@marketops.in" style="color: inherit; text-decoration: none;">connect@marketops.in</a></p>
              </div>
            </div>
          </div>

          <!-- Social Bar -->
          <div class="social-connect-bar">
            <span>Connect With Us</span>
            <div class="social-pills">
              <!-- Instagram -->
              <a href="#" class="social-pill" style="background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
              </a>
              <!-- LinkedIn -->
              <a href="#" class="social-pill" style="background: #0077b5;">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
              </a>
              <!-- Facebook -->
              <a href="#" class="social-pill" style="background: #1877f2;">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"></path></svg>
              </a>
              <!-- X (Twitter) -->
              <a href="#" class="social-pill" style="background: #000; border: 1px solid rgba(255,255,255,0.2);">
                <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"></path></svg>
              </a>
            </div>
          </div>
          
        </div>
        
      </div>
    </div>
  </section>

  <style>
    /* Contact Layout Styles */
    .contact-split-wrapper {
      display: flex;
      flex-direction: column;
      align-items: center;
      max-width: 900px;
      margin: 0 auto;
    }

    .contact-info-panel {
      width: 100%;
    }

    /* Info Panel Content */
    .info-title {
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 700;
      color: #fff;
      margin-bottom: 1rem;
      line-height: 1.2;
      font-family: var(--font-heading);
      text-align: center;
    }

    .info-subtitle {
      font-size: 1.1rem;
      color: var(--color-text-muted);
      margin-bottom: 3rem;
      line-height: 1.6;
      max-width: 90%;
      text-align: center;
      margin-left: auto;
      margin-right: auto;
    }

    .info-grid-2x2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      margin-bottom: 3rem;
    }

    @media (max-width: 500px) {
      .info-grid-2x2 {
        grid-template-columns: 1fr;
      }
    }

    .info-glass-card {
      background: linear-gradient(145deg, rgba(15, 20, 35, 0.7), rgba(10, 15, 25, 0.9));
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 24px;
      padding: 2.5rem 2rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 1rem;
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      position: relative;
      overflow: hidden;
    }

    .info-glass-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0; height: 100%;
      background: radial-gradient(circle at top, rgba(0, 198, 255, 0.1), transparent 60%);
      opacity: 0;
      transition: opacity 0.4s ease;
      pointer-events: none;
    }

    .info-glass-card:hover {
      background: rgba(20, 25, 45, 0.8);
      border-color: rgba(0, 198, 255, 0.3);
      transform: translateY(-8px);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5), 0 0 20px rgba(0, 198, 255, 0.1);
    }

    .info-glass-card:hover::before {
      opacity: 1;
    }

    .info-icon {
      width: 60px;
      height: 60px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.03);
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1px solid rgba(255, 255, 255, 0.1);
      transition: transform 0.4s ease;
    }

    .info-glass-card:hover .info-icon {
      transform: scale(1.1) rotate(5deg);
      border-color: currentColor;
    }

    .info-content h4 {
      color: #fff;
      font-size: 1.3rem;
      margin-bottom: 0.5rem;
      font-weight: 700;
    }

    .info-content p {
      color: rgba(255, 255, 255, 0.65);
      font-size: 1rem;
      line-height: 1.6;
      margin: 0;
    }

    .social-connect-bar {
      background: linear-gradient(90deg, rgba(15, 20, 35, 0.6), rgba(10, 15, 25, 0.8));
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 50px;
      padding: 1.5rem 3rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1.5rem;
      box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }

    .social-connect-bar span {
      color: #fff;
      font-weight: 700;
      font-size: 1.2rem;
      letter-spacing: 0.5px;
    }

    .social-pills {
      display: flex;
      gap: 1rem;
    }

    .social-pill {
      width: 45px;
      height: 45px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    }

    .social-pill:hover {
      transform: scale(1.15) translateY(-3px);
      box-shadow: 0 10px 20px rgba(0,0,0,0.4);
    }
      box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
    }

    /* Left Side Calendar Glass Panel */
    .calendar-glass-box {
      background: rgba(11, 15, 25, 0.7);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 30px;
      padding: 3rem 2.5rem;
      box-shadow: 0 30px 60px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(255, 255, 255, 0.1);
      position: relative;
    }

    .calendar-title {
      text-align: center;
      font-size: 1.4rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: 2rem;
    }

    .calendar-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1.5rem;
      padding: 0 1rem;
    }

    .cal-nav-btn {
      background: transparent;
      border: none;
      color: rgba(255, 255, 255, 0.6);
      cursor: pointer;
      transition: color 0.3s ease;
    }

    .cal-nav-btn:hover {
      color: #fff;
    }

    .cal-month {
      color: #fff;
      font-weight: 600;
      font-size: 1.1rem;
    }

    .calendar-grid {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 0.5rem;
      text-align: center;
    }

    .cal-day-name {
      color: rgba(0, 198, 255, 0.8);
      font-size: 0.8rem;
      font-weight: 600;
      text-transform: uppercase;
      margin-bottom: 0.5rem;
    }

    .cal-date {
      height: 38px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: rgba(255, 255, 255, 0.7);
      font-size: 0.95rem;
      font-weight: 500;
      border-radius: 50%;
      cursor: pointer;
      position: relative;
      transition: all 0.2s ease;
    }

    .cal-date:not(.empty):hover {
      background: rgba(255, 255, 255, 0.1);
      color: #fff;
    }

    .has-event::after {
      content: '';
      position: absolute;
      bottom: 2px;
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: #00c6ff;
    }

    .active-date {
      background: #00c6ff !important;
      color: #000 !important;
      box-shadow: 0 0 15px rgba(0, 198, 255, 0.5);
    }

    .active-range {
      background: rgba(0, 198, 255, 0.2);
      color: #fff;
      border-radius: 0;
    }
  </style>
</Layout>
