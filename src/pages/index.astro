---
import Layout from '../layouts/Layout.astro';
---

<Layout title="MarketOps | Performance Marketing & Digital Ads Agency">
  <!-- HERO LANDING SECTION -->
  <section class="hero-wrapper" style="position: relative; overflow: hidden; background: #050810;">
    <canvas id="homeCanvas" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none; opacity: 0.8;"></canvas>
    <div class="hero-overlay" style="background: linear-gradient(180deg, rgba(5, 8, 16, 0.4) 0%, var(--bg-main) 100%); z-index: 1;"></div>
    <div class="container" style="position: relative; z-index: 2; text-align: center;">
      <div class="reveal-on-scroll">
        <h1 class="gradient-text" style="font-size: clamp(2.2rem, 6vw, 4.8rem); max-width: 900px; margin: 0 auto 1.5rem; text-transform: capitalize;">
          Built for the brands<br>that <span class="gradient-text-alt" style="font-weight: 800;">don’t settle</span>
        </h1>
        <p style="font-size: clamp(1rem, 2.5vw, 1.25rem); color: var(--color-text-muted); max-width: 600px; margin: 0 auto 2.5rem;">
          Trusted by brands that demand control, consistency, compliance, and explosive performance
        </p>
        <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
          <a href="#calendly" class="btn btn-primary">Talk to Our Team</a>
          <a href="#video-showcase" class="btn btn-secondary">See How We Work</a>
        </div>
      </div>
    </div>
  </section>

  <!-- SHOWREEL MOUNT SECTION -->
  <section id="video-showcase" class="section-padding" style="background: #0d121f;">
    <div class="container">
      <div class="reveal-on-scroll" style="text-align: center; margin-bottom: 3.5rem;">
        <h2 style="font-size: clamp(1.8rem, 4vw, 2.8rem); margin-bottom: 1rem;">Showcasing Growth Operations</h2>
        <p style="color: var(--color-text-muted); max-width: 600px; margin: 0 auto;">Watch how we construct and scale data-driven growth pipelines.</p>
      </div>
      
      <div class="video-section-wrapper reveal-on-scroll">
        <video src="/assets/home/home.webm" autoplay loop muted playsinline></video>
        <button class="mute-btn-overlay">🔇 Muted</button>
      </div>
    </div>
  </section>

  <!-- AD SPENDS LOGO SCROLLER -->
  <section class="section-padding" style="background: var(--bg-main); overflow: hidden;">
    <div class="container">
      <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 3rem; align-items: center;">
        <div class="reveal-on-scroll">
          <div class="badge-lead">MarketOps Spent</div>
          <h3 class="gradient-text" style="font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 900; margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0.2rem;">
            $<span class="counter-number" data-target="100351886" data-format="true">0</span>+
          </h3>
          <p style="color: var(--color-text-muted); font-size: 1.1rem; font-weight: 500;">
            Just a normal month of paid advertising spends managed by MarketOps growth partners.
          </p>
        </div>
        
        <div class="marquee-container reveal-on-scroll">
          <div class="marquee-content">
            <div class="marquee-card"><img src="/assets/spends/bhs.png" alt="BHS spend partner"></div>
            <div class="marquee-card"><img src="/assets/spends/cured.png" alt="Cured spend partner"></div>
            <div class="marquee-card"><img src="/assets/spends/ES.png" alt="ES spend partner"></div>
            <div class="marquee-card"><img src="/assets/spends/ghar.png" alt="Ghar spend partner"></div>
            <div class="marquee-card"><img src="/assets/spends/histrips.png" alt="Histrips spend partner"></div>
            <div class="marquee-card"><img src="/assets/spends/HOA.png" alt="HOA spend partner"></div>
            <div class="marquee-card"><img src="/assets/spends/natures-sunrise.png" alt="Natures Sunrise spend partner"></div>
            <div class="marquee-card"><img src="/assets/spends/obsessive.png" alt="Obsessive spend partner"></div>
            <div class="marquee-card"><img src="/assets/spends/old-money.png" alt="Old Money spend partner"></div>
            <div class="marquee-card"><img src="/assets/spends/sana.png" alt="Sana spend partner"></div>
            <!-- Duplicated for infinite scroll -->
            <div class="marquee-card"><img src="/assets/spends/bhs.png" alt="BHS spend partner"></div>
            <div class="marquee-card"><img src="/assets/spends/cured.png" alt="Cured spend partner"></div>
            <div class="marquee-card"><img src="/assets/spends/ES.png" alt="ES spend partner"></div>
            <div class="marquee-card"><img src="/assets/spends/ghar.png" alt="Ghar spend partner"></div>
            <div class="marquee-card"><img src="/assets/spends/histrips.png" alt="Histrips spend partner"></div>
            <div class="marquee-card"><img src="/assets/spends/HOA.png" alt="HOA spend partner"></div>
            <div class="marquee-card"><img src="/assets/spends/natures-sunrise.png" alt="Natures Sunrise spend partner"></div>
            <div class="marquee-card"><img src="/assets/spends/obsessive.png" alt="Obsessive spend partner"></div>
            <div class="marquee-card"><img src="/assets/spends/old-money.png" alt="Old Money spend partner"></div>
            <div class="marquee-card"><img src="/assets/spends/sana.png" alt="Sana spend partner"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- GROWTH PARTNERS LOGO MARQUEE -->
  <section class="section-padding" style="background: #0a0d16; border-top: 1px solid var(--border-light); border-bottom: 1px solid var(--border-light); overflow: hidden;">
    <div class="container">
      <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 3rem; align-items: center;">
        <div class="reveal-on-scroll">
          <div class="badge-lead">Global Channels</div>
          <h3 class="gradient-text" style="font-size: 2rem; margin-bottom: 0.5rem; font-weight: 700;">Growth Partners</h3>
          <p style="color: var(--color-text-muted); font-size: 1rem;">Backed and supported by the channels that shape the advertising industry.</p>
        </div>
        
        <div class="marquee-container reveal-on-scroll">
          <div class="marquee-content">
            <div class="marquee-card"><img src="/assets/logos/skala-media.png" alt="Skala Media logo"></div>
            <div class="marquee-card"><img src="/assets/logos/suits-finnance.png" alt="Suits Finance logo"></div>
            <div class="marquee-card"><img src="/assets/logos/whop.png" alt="Whop logo"></div>
            <div class="marquee-card"><img src="/assets/logos/ooptics.png" alt="Ooptics logo"></div>
            <div class="marquee-card"><img src="/assets/logos/incogniton.png" alt="Incogniton logo"></div>
            <div class="marquee-card"><img src="/assets/logos/tiktok.png" alt="TikTok logo"></div>
            <div class="marquee-card"><img src="/assets/logos/google.png" alt="Google partner logo"></div>
            <div class="marquee-card"><img src="/assets/logos/growthmodo.png" alt="Growthmodo logo"></div>
            <div class="marquee-card"><img src="/assets/logos/meta.png" alt="Meta partner logo"></div>
            <div class="marquee-card"><img src="/assets/logos/slash.png" alt="Slash logo"></div>
            <div class="marquee-card"><img src="/assets/logos/ecover-solutions.png" alt="eCover Solutions logo"></div>
            <div class="marquee-card"><img src="/assets/logos/swaped.png" alt="Swapd logo"></div>
            <div class="marquee-card"><img src="/assets/logos/snapchat-v1.png" alt="Snapchat logo"></div>
            <div class="marquee-card"><img src="/assets/logos/nexcale.png" alt="Nexcale logo"></div>
            <!-- Duplicated for infinite scroll -->
            <div class="marquee-card"><img src="/assets/logos/skala-media.png" alt="Skala Media logo"></div>
            <div class="marquee-card"><img src="/assets/logos/suits-finnance.png" alt="Suits Finance logo"></div>
            <div class="marquee-card"><img src="/assets/logos/whop.png" alt="Whop logo"></div>
            <div class="marquee-card"><img src="/assets/logos/ooptics.png" alt="Ooptics logo"></div>
            <div class="marquee-card"><img src="/assets/logos/incogniton.png" alt="Incogniton logo"></div>
            <div class="marquee-card"><img src="/assets/logos/tiktok.png" alt="TikTok logo"></div>
            <div class="marquee-card"><img src="/assets/logos/google.png" alt="Google partner logo"></div>
            <div class="marquee-card"><img src="/assets/logos/growthmodo.png" alt="Growthmodo logo"></div>
            <div class="marquee-card"><img src="/assets/logos/meta.png" alt="Meta partner logo"></div>
            <div class="marquee-card"><img src="/assets/logos/slash.png" alt="Slash logo"></div>
            <div class="marquee-card"><img src="/assets/logos/ecover-solutions.png" alt="eCover Solutions logo"></div>
            <div class="marquee-card"><img src="/assets/logos/swaped.png" alt="Swapd logo"></div>
            <div class="marquee-card"><img src="/assets/logos/snapchat-v1.png" alt="Snapchat logo"></div>
            <div class="marquee-card"><img src="/assets/logos/nexcale.png" alt="Nexcale logo"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 6-SERVICE BENTO GRID SHOWCASE -->
  <section class="section-padding" style="background: var(--bg-main); position: relative;">
    <div style="position: absolute; top: 10%; left: 5%; width: 300px; height: 300px; background: rgba(0, 198, 255, 0.05); filter: blur(80px); border-radius: 50%; pointer-events: none;"></div>
    <div style="position: absolute; bottom: 10%; right: 5%; width: 300px; height: 300px; background: rgba(12, 59, 251, 0.05); filter: blur(80px); border-radius: 50%; pointer-events: none;"></div>

    <div class="container">
      <div class="reveal-on-scroll" style="text-align: center; margin-bottom: 5rem;">
        <div class="badge-lead">Core Capabilities</div>
        <h2 style="font-size: clamp(2rem, 5vw, 3rem); margin-bottom: 1.5rem;">
          From Concept to <span class="gradient-text">Market Leadership</span>
        </h2>
        <p style="color: var(--color-text-muted); max-width: 650px; margin: 0 auto;">
          We help turn your ideas into successful brands with smart marketing, strong digital presence, and customer-focused strategies. From building awareness to growing sales, our goal is to help your business stand out, connect with people, and grow with confidence in a competitive market.
        </p>
      </div>

      <!-- CREATIVE FLOATING TIMELINE JOURNEY -->
      <div style="position: relative; max-width: 850px; margin: 0 auto; padding: 2rem 0 2rem 1.5rem;">
        <!-- Glowing Vertical Connecting Line -->
        <div style="position: absolute; left: 1.5rem; top: 0; bottom: 0; width: 2px; background: linear-gradient(to bottom, transparent, rgba(0,198,255,0.5) 15%, rgba(255,63,108,0.5) 85%, transparent); z-index: 0;"></div>

        <!-- Step 1 -->
        <div class="reveal-on-scroll" style="position: relative; padding-left: 4rem; margin-bottom: 5rem;">
          <!-- Node -->
          <div style="position: absolute; left: -23px; top: 0; width: 50px; height: 50px; background: var(--bg-main); border: 2px solid #00c6ff; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #00c6ff; box-shadow: 0 0 25px rgba(0,198,255,0.4); z-index: 2;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
          </div>
          <!-- Abstract Glow -->
          <div style="position: absolute; top: -30px; left: 50px; width: 150px; height: 150px; background: rgba(0, 198, 255, 0.08); filter: blur(40px); border-radius: 50%; pointer-events: none;"></div>
          <!-- Content -->
          <div style="position: relative; z-index: 1;">
            <div style="font-size: 0.85rem; font-weight: 800; letter-spacing: 3px; color: #00c6ff; margin-bottom: 0.5rem;">PHASE 01</div>
            <h3 style="font-size: clamp(1.8rem, 4vw, 2.4rem); color: #fff; margin-bottom: 1rem; font-family: var(--font-heading); line-height: 1.2;">Market Research &amp; Analysis</h3>
            <p style="color: var(--color-text-muted); font-size: 1.15rem; line-height: 1.7; max-width: 650px;">
              Understanding your audience, analyzing competitors, and discovering the absolute best opportunities for your brand to dominate the market with data-backed decisions.
            </p>
            <div style="position: relative; z-index: 1; margin-top: 1.5rem; max-width: 650px; border-radius: 16px; overflow: hidden; border: 1px solid rgba(255,255,255,0.05); aspect-ratio: 16/7; box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
              <img src="/assets/images/real_research.webp" alt="Market Research Team" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'" />
            </div>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="reveal-on-scroll" style="position: relative; padding-left: 4rem; margin-bottom: 5rem;">
          <!-- Node -->
          <div style="position: absolute; left: -23px; top: 0; width: 50px; height: 50px; background: var(--bg-main); border: 2px solid #ff9900; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #ff9900; box-shadow: 0 0 25px rgba(255,153,0,0.4); z-index: 2;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>
          </div>
          <!-- Abstract Glow -->
          <div style="position: absolute; top: -30px; left: 50px; width: 150px; height: 150px; background: rgba(255, 153, 0, 0.08); filter: blur(40px); border-radius: 50%; pointer-events: none;"></div>
          <!-- Content -->
          <div style="position: relative; z-index: 1;">
            <div style="font-size: 0.85rem; font-weight: 800; letter-spacing: 3px; color: #ff9900; margin-bottom: 0.5rem;">PHASE 02</div>
            <h3 style="font-size: clamp(1.8rem, 4vw, 2.4rem); color: #fff; margin-bottom: 1rem; font-family: var(--font-heading); line-height: 1.2;">Strong Digital Presence</h3>
            <p style="color: var(--color-text-muted); font-size: 1.15rem; line-height: 1.7; max-width: 650px;">
              Building modern, high-performing websites and optimizing your brand across all digital touchpoints to leave a lasting, premium impression.
            </p>
            <div style="position: relative; z-index: 1; margin-top: 1.5rem; max-width: 650px; border-radius: 16px; overflow: hidden; border: 1px solid rgba(255,255,255,0.05); aspect-ratio: 16/7; box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
              <img src="/assets/images/real_digital.webp" alt="Digital Presence Laptop" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'" />
            </div>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="reveal-on-scroll" style="position: relative; padding-left: 4rem; margin-bottom: 5rem;">
          <!-- Node -->
          <div style="position: absolute; left: -23px; top: 0; width: 50px; height: 50px; background: var(--bg-main); border: 2px solid #5a7cff; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #5a7cff; box-shadow: 0 0 25px rgba(90,124,255,0.4); z-index: 2;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 3.82-13.1c1.37-1.74 3.79-1.92 5.09-.61 1.3 1.3 1.48 3.73-.26 5.1A22 22 0 0 1 12 15z"/><path d="m16 9-3-3"/></svg>
          </div>
          <!-- Abstract Glow -->
          <div style="position: absolute; top: -30px; left: 50px; width: 150px; height: 150px; background: rgba(90, 124, 255, 0.08); filter: blur(40px); border-radius: 50%; pointer-events: none;"></div>
          <!-- Content -->
          <div style="position: relative; z-index: 1;">
            <div style="font-size: 0.85rem; font-weight: 800; letter-spacing: 3px; color: #5a7cff; margin-bottom: 0.5rem;">PHASE 03</div>
            <h3 style="font-size: clamp(1.8rem, 4vw, 2.4rem); color: #fff; margin-bottom: 1rem; font-family: var(--font-heading); line-height: 1.2;">Strategic Marketing</h3>
            <p style="color: var(--color-text-muted); font-size: 1.15rem; line-height: 1.7; max-width: 650px;">
              Running highly targeted and algorithmically optimized ad campaigns across Google, Meta, and others to maximize reach and predictably scale sales.
            </p>
            <div style="position: relative; z-index: 1; margin-top: 1.5rem; max-width: 650px; border-radius: 16px; overflow: hidden; border: 1px solid rgba(255,255,255,0.05); aspect-ratio: 16/7; box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
              <img src="/assets/images/real_marketing.webp" alt="Strategic Marketing Ads" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'" />
            </div>
          </div>
        </div>

        <!-- Step 4 -->
        <div class="reveal-on-scroll" style="position: relative; padding-left: 4rem; margin-bottom: 5rem;">
          <!-- Node -->
          <div style="position: absolute; left: -23px; top: 0; width: 50px; height: 50px; background: var(--bg-main); border: 2px solid #00ffa3; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #00ffa3; box-shadow: 0 0 25px rgba(0,255,163,0.4); z-index: 2;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </div>
          <!-- Abstract Glow -->
          <div style="position: absolute; top: -30px; left: 50px; width: 150px; height: 150px; background: rgba(0, 255, 163, 0.08); filter: blur(40px); border-radius: 50%; pointer-events: none;"></div>
          <!-- Content -->
          <div style="position: relative; z-index: 1;">
            <div style="font-size: 0.85rem; font-weight: 800; letter-spacing: 3px; color: #00ffa3; margin-bottom: 0.5rem;">PHASE 04</div>
            <h3 style="font-size: clamp(1.8rem, 4vw, 2.4rem); color: #fff; margin-bottom: 1rem; font-family: var(--font-heading); line-height: 1.2;">Customer Insights</h3>
            <p style="color: var(--color-text-muted); font-size: 1.15rem; line-height: 1.7; max-width: 650px;">
              Gathering actionable, deep-level insights to refine your products, improve experiences, and build long-term, unshakeable brand loyalty.
            </p>
            <div style="position: relative; z-index: 1; margin-top: 1.5rem; max-width: 650px; border-radius: 16px; overflow: hidden; border: 1px solid rgba(255,255,255,0.05); aspect-ratio: 16/7; box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
              <img src="/assets/images/real_insights.webp" alt="Customer Insights Data" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'" />
            </div>
          </div>
        </div>

        <!-- Step 5 -->
        <div class="reveal-on-scroll" style="position: relative; padding-left: 4rem;">
          <!-- Node -->
          <div style="position: absolute; left: -23px; top: 0; width: 50px; height: 50px; background: var(--bg-main); border: 2px solid #ff3f6c; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #ff3f6c; box-shadow: 0 0 25px rgba(255,63,108,0.4); z-index: 2;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <!-- Abstract Glow -->
          <div style="position: absolute; top: -30px; left: 50px; width: 150px; height: 150px; background: rgba(255, 63, 108, 0.08); filter: blur(40px); border-radius: 50%; pointer-events: none;"></div>
          <!-- Content -->
          <div style="position: relative; z-index: 1;">
            <div style="font-size: 0.85rem; font-weight: 800; letter-spacing: 3px; color: #ff3f6c; margin-bottom: 0.5rem;">PHASE 05</div>
            <h3 style="font-size: clamp(1.8rem, 4vw, 2.4rem); color: #fff; margin-bottom: 1rem; font-family: var(--font-heading); line-height: 1.2;">After-Sales Support</h3>
            <p style="color: var(--color-text-muted); font-size: 1.15rem; line-height: 1.7; max-width: 650px;">
              Providing dedicated, elite-tier support to your customers post-purchase, ensuring satisfaction, resolving issues rapidly, and encouraging strong repeat business.
            </p>
            <div style="position: relative; z-index: 1; margin-top: 1.5rem; max-width: 650px; border-radius: 16px; overflow: hidden; border: 1px solid rgba(255,255,255,0.05); aspect-ratio: 16/7; box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
              <img src="/assets/images/real_support.webp" alt="After Sales Support" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- COUNTER METRICS SECTION -->
  <section class="section-padding" style="background: #080c14; border-top: 1px solid var(--border-light); border-bottom: 1px solid var(--border-light);">
    <div class="container">
      <div class="reveal-on-scroll" style="text-align: center; margin-bottom: 4rem;">
        <h2 style="font-size: clamp(1.8rem, 4vw, 2.8rem); margin-bottom: 1.5rem;">When Infrastructure & Creative Work Together</h2>
        <p style="color: var(--color-text-muted); max-width: 600px; margin: 0 auto;">
          Real, verifiable data averages recorded across our portfolio partners in the last 12 months.
        </p>
      </div>
      
      <!-- CREATIVE FLOATING STATS LAYOUT (No Boxes) -->
      <div style="display: flex; flex-wrap: wrap; justify-content: center; align-items: center; gap: 4rem; position: relative; padding: 4rem 0;">
        
        <!-- Center Abstract Tech Graphic -->
        <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 100%; height: 100%; display: flex; justify-content: center; align-items: center; pointer-events: none; z-index: 0; opacity: 0.5;">
          <div style="width: 300px; height: 300px; border-radius: 50%; border: 1px dashed rgba(0, 198, 255, 0.3); animation: spin 20s linear infinite; position: absolute;"></div>
          <div style="width: 450px; height: 450px; border-radius: 50%; border: 1px dotted rgba(255, 255, 255, 0.1); animation: spin 30s linear infinite reverse; position: absolute;"></div>
          <div style="width: 500px; height: 500px; background: radial-gradient(circle, rgba(0,198,255,0.05) 0%, transparent 60%); position: absolute; filter: blur(40px);"></div>
        </div>

        <!-- Stat 1 (Left Aligned Text, Right Border) -->
