  <!-- HOME PAGE CANVAS ANIMATION SCRIPT -->
  <script>
    const canvas = document.getElementById('homeCanvas') as HTMLCanvasElement;
    if (canvas) {
      const ctx = canvas.getContext('2d');
      
      let w, h, nodes;
      const nodeCount = 100;
      // High-end SaaS Brand Colors: Cyan, Deep Purple, Pink
      const colors = ['#00e5ff', '#b53cff', '#ff3f6c'];

      function resize() {
        const parent = canvas.parentElement;
        w = canvas.width = parent.offsetWidth;
        h = canvas.height = parent.offsetHeight;
      }

      class Node {
        x: number;
        y: number;
        vx: number;
        vy: number;
        radius: number;
        color: string;

        constructor() {
          this.x = Math.random() * w;
          this.y = Math.random() * h;
          // Slower, more elegant movement for homepage
          this.vx = (Math.random() - 0.5) * 0.8;
          this.vy = (Math.random() - 0.5) * 0.8;
          this.radius = Math.random() * 2 + 1;
          this.color = colors[Math.floor(Math.random() * colors.length)];
        }

        update() {
          this.x += this.vx;
          this.y += this.vy;
          
          if (this.x < 0 || this.x > w) this.vx *= -1;
          if (this.y < 0 || this.y > h) this.vy *= -1;
        }

        draw() {
          if(!ctx) return;
          ctx.beginPath();
          ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
          ctx.fillStyle = this.color;
          ctx.fill();
          ctx.shadowBlur = 15;
          ctx.shadowColor = this.color;
        }
      }

      function init() {
        resize();
        nodes = [];
        for(let i=0; i<nodeCount; i++) {
          nodes.push(new Node());
        }
      }

      function animate() {
        if(!ctx) return;
        // Subtle dark trail for premium blur effect
        ctx.fillStyle = 'rgba(5, 8, 16, 0.2)'; 
        ctx.fillRect(0, 0, w, h);
        
        nodes.forEach(n => {
          n.update();
          n.draw();
        });
        
        // Draw constellation connections
        for(let i=0; i<nodes.length; i++) {
          for(let j=i+1; j<nodes.length; j++) {
            const dx = nodes[i].x - nodes[j].x;
            const dy = nodes[i].y - nodes[j].y;
            const dist = Math.sqrt(dx*dx + dy*dy);
            
            // Connect nodes if they are close enough
            if(dist < 150) {
              ctx.beginPath();
              // Opacity depends on distance
              ctx.strokeStyle = `rgba(0, 229, 255, ${0.15 - dist/1000})`;
              ctx.lineWidth = 0.6;
              ctx.moveTo(nodes[i].x, nodes[i].y);
              ctx.lineTo(nodes[j].x, nodes[j].y);
              ctx.stroke();
            }
          }
        }
        
        requestAnimationFrame(animate);
      }

      window.addEventListener('resize', resize);
      init();
      animate();
    }
  </script>
