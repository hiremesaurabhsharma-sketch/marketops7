---
import Layout from '../layouts/Layout.astro';

const baseCases = [
  {
    title: "Obsessive Scaled to 8-Figures",
    tag: "Apparel & Fashion",
    desc: "Achieved record growth through precision targeting and retention workflows.",
    metrics: [{ val: "4.5x", label: "ROAS" }, { val: "+210%", label: "Growth" }],
    img: "/assets/spends/obsessive.png"
  },
  {
    title: "BHS Global Expansion",
    tag: "DTC Wellness",
    desc: "Scaled international campaigns while reducing overall acquisition costs.",
    metrics: [{ val: "$2M+", label: "Spend Scaled" }, { val: "-35%", label: "CAC" }],
    img: "/assets/spends/bhs.png"
  },
  {
    title: "Histrips Lead Generation Domination",
    tag: "Travel",
    desc: "Captured high-intent travelers globally, bypassing traditional OTA monopolies.",
    metrics: [{ val: "15K+", label: "Leads" }, { val: "5x", label: "Volume" }],
    img: "/assets/spends/histrips.png"
  },
  {
    title: "Cured E-commerce Takeoff",
    tag: "Skincare",
    desc: "Re-engineered checkout funnels to boost conversion rates and lifetime value.",
    metrics: [{ val: "3.2x", label: "LTV Increase" }, { val: "+150%", label: "Revenue" }],
    img: "/assets/spends/cured.png"
  },
  {
    title: "Sana Retail Expansion",
    tag: "FMCG",
    desc: "Omnichannel strategy blending offline POS data with online ad sequencing.",
    metrics: [{ val: "8.5x", label: "Store Visits" }, { val: "+340%", label: "Sales" }],
    img: "/assets/spends/sana.png"
  },
  {
    title: "Whop SaaS User Acquisition",
    tag: "B2B SaaS",
    desc: "Targeted enterprise operators to acquire high-ticket long term subscriptions.",
    metrics: [{ val: "-45%", label: "CAC" }, { val: "$5M+", label: "ARR Added" }],
    img: "/assets/logos/whop.png"
  }
];

const regions = ["North America", "Europe", "APAC", "Global", "MENA", "LATAM", "ANZ"];
const caseStudies = [];
for (let i = 0; i < 100; i++) {
  const base = baseCases[i % baseCases.length];
  const region = regions[i % regions.length];
  
  caseStudies.push({
    id: `cs-${i + 1}`,
    title: i < 6 ? base.title : `${base.title.split(' ')[0]} ${region} Expansion`,
    tag: base.tag,
    desc: base.desc,
    metrics: base.metrics,
    img: base.img
  });
}
---

<Layout title="Case Studies &amp; Performance Showreel | MarketOps" description="Explore real results and D2C scaling metrics achieved by MarketOps. Verified performance marketing, e-commerce, SEO, and global business case studies.">
  <!-- HERO SECTION -->
  <section class="hero-wrapper">
    <div class="hero-overlay" style="background: linear-gradient(180deg, rgba(11, 15, 25, 0.4) 0%, var(--bg-main) 100%);"></div>
    <div class="container" style="position: relative; z-index: 1; text-align: center;">
      <div class="reveal-on-scroll">
        <div class="badge-lead">Verified Brand Metrics</div>
        <h1 class="gradient-text" style="font-size: clamp(2.2rem, 6vw, 4.2rem); max-width: 950px; margin: 0 auto 1.5rem;">
          Real Growth. Proven Results. <br><span class="gradient-text-alt" style="font-weight: 800;">Zero Algorithmic Fluff.</span>
        </h1>
        <p style="font-size: clamp(1rem, 2.5vw, 1.25rem); color: var(--color-text-muted); max-width: 700px; margin: 0 auto 2.5rem;">
          Explore real direct-response statistics, marketplace scale metrics, search authority growth, and B2B expansion case studies from our verified portfolio partners.
        </p>
        <div style="display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap;">
          <a href="#case-studies-grid" class="btn btn-primary">View Case Studies</a>
          <a href="#stats" class="btn btn-secondary">See Core Numbers</a>
        </div>
      </div>
    </div>
  </section>

  <!-- COUNTER STATS SECTION -->
  <section id="stats" class="section-padding" style="background: #0d121f; border-top: 1px solid var(--border-light); border-bottom: 1px solid var(--border-light);">
    <div class="container">
      <div class="counter-grid">
        <div class="counter-card reveal-on-scroll">
          <div class="counter-number gradient-text" data-target="500" data-suffix="+">0</div>
          <div class="counter-label" style="font-weight: 600; color: var(--color-accent-cyan); font-family: var(--font-heading); font-size: 1.1rem; margin-bottom: 0.25rem;">Active Clients</div>
          <div style="color: var(--color-text-muted); font-size: 0.85rem;">Profitably scaling globally</div>
        </div>
        <div class="counter-card reveal-on-scroll">
          <div class="counter-number gradient-text" data-target="6" data-suffix="M+">0</div>
          <div class="counter-label" style="font-weight: 600; color: var(--color-accent-cyan); font-family: var(--font-heading); font-size: 1.1rem; margin-bottom: 0.25rem;">Monthly Ad Spend</div>
          <div style="color: var(--color-text-muted); font-size: 0.85rem;">Managed across ad portals</div>
        </div>
        <div class="counter-card reveal-on-scroll">
          <div class="counter-number gradient-text" data-target="1000" data-suffix="+">0</div>
          <div class="counter-label" style="font-weight: 600; color: var(--color-accent-cyan); font-family: var(--font-heading); font-size: 1.1rem; margin-bottom: 0.25rem;">Total Case Studies</div>
          <div style="color: var(--color-text-muted); font-size: 0.85rem;">Successfully recorded results</div>
        </div>
        <div class="counter-card reveal-on-scroll">
          <div class="counter-number gradient-text" data-target="100" data-suffix="+">0</div>
          <div class="counter-label" style="font-weight: 600; color: var(--color-accent-cyan); font-family: var(--font-heading); font-size: 1.1rem; margin-bottom: 0.25rem;">Globally Launched Brands</div>
          <div style="color: var(--color-text-muted); font-size: 0.85rem;">With sustainable expansion</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CASE STUDIES GRID & DASHBOARD -->
  <section id="case-studies-grid" class="section-padding" style="background: var(--bg-main);">
    <div class="container">
      <div class="reveal-on-scroll" style="text-align: center; margin-bottom: 4rem;">
        <div class="badge-lead">Success Showcases</div>
        <h2 style="font-size: clamp(1.8rem, 4vw, 2.8rem); margin-bottom: 1.5rem;">Proven Results Across 6 Service Verticals</h2>
        <p style="color: var(--color-text-muted); max-width: 600px; margin: 0 auto;">See how our specialized systems translate data into profit margins.</p>
      </div>

      <!-- Live Dashboard Control Center -->
      <div class="cases-dashboard-controls reveal-on-scroll">
        <div class="controls-top-row">
          <!-- Live Interactive Search -->
          <div class="search-input-wrapper">
            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
            <input type="text" id="search-cases" class="search-input" placeholder="Search case study (e.g. Amazon, ROAS, Next.js, SEO)...">
          </div>
          <!-- Sort Options -->
          <div class="sort-select-wrapper">
            <select id="sort-cases" class="sort-select">
              <option value="relevance">Sort by Relevance</option>
              <option value="growth-desc">Growth Rate: High to Low</option>
              <option value="growth-asc">Growth Rate: Low to High</option>
            </select>
          </div>
        </div>
        <!-- Filter Tabs -->
        <div class="filter-tabs-wrapper" id="filter-tabs">
          <!-- Dynamic filter buttons populated by JS -->
        </div>
      </div>

      <!-- Cases Output Container Grid -->
      <div class="grid-3" id="cases-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 2rem; margin-top: 3rem;">
        {caseStudies.map((cs, index) => (
          <div class="cs-card reveal-on-scroll cs-card-item" data-index={index} data-id={cs.id} style={index >= 12 ? 'display: none;' : 'cursor: pointer;'}>
            <div class="cs-logo-wrapper">
              <img src={cs.img} alt={cs.title} />
            </div>
            <span class="cs-tag">{cs.tag}</span>
            <h3 style="font-size: 1.5rem; color: #fff; margin-bottom: 1rem; line-height: 1.3;">{cs.title}</h3>
            <p style="color: var(--color-text-muted); margin-bottom: 2rem; line-height: 1.6; font-size: 0.95rem;">{cs.desc}</p>
            <div class="cs-metrics">
              {cs.metrics.map(m => (
                <div class="cs-metric">
                  <span class="cs-metric-val">{m.val}</span>
                  <span class="cs-metric-label">{m.label}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- Load More & Pagination Options -->
      <div class="load-more-container" id="load-more-container">
        <button class="btn btn-primary" id="btn-load-more" style="border-radius: 50px;">Load More Case Studies</button>
        <div class="load-count-info" id="load-count-info">Showing 0 of 0 case studies</div>
      </div>
    </div>
  </section>

  <!-- GLASSMORPHIC CASE DETAILS DYNAMIC MODAL -->
  <div class="case-modal" id="caseModal">
    <div class="case-modal-backdrop" id="caseModalBackdrop"></div>
    <div class="case-modal-window">
      <button class="case-modal-close" id="caseModalClose" aria-label="Close modal">&times;</button>
      <div id="caseModalContent">
        <!-- Injected dynamic content blueprint -->
      </div>
    </div>
  </div>

  <!-- CALENDLY EMBED SECTION -->
  <section id="calendly" class="section-padding" style="background: #080c14; border-top: 1px solid var(--border-light); border-bottom: 1px solid var(--border-light);">
    <div class="container">
      <div class="reveal-on-scroll" style="text-align: center; margin-bottom: 4rem;">
        <h2 style="font-size: 2.5rem; margin-bottom: 1rem;">Setup Your Free Portfolio Review</h2>
        <p style="color: var(--color-text-muted); max-width: 600px; margin: 0 auto;">Connect with a growth partner to review relevant case studies from your industry sector.</p>
      </div>
      
      <div class="calendly-section reveal-on-scroll">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; padding: 2rem;">
          <div>
            <h3 style="font-size: 1.8rem; margin-bottom: 1rem;">What We Will Discover:</h3>
            <ul style="list-style: none; display: flex; flex-direction: column; gap: 1.2rem; margin: 2rem 0;">
              <li style="display: flex; gap: 0.75rem; align-items: flex-start;">
                <span style="color: var(--color-accent-cyan); font-weight: bold;">[01]</span>
                <div>
                  <h4 style="font-size: 1.05rem; margin-bottom: 0.15rem;">Industry Matching Case Walkthrough</h4>
                  <p style="color: var(--color-text-muted); font-size: 0.85rem;">Review the exact visual assets, bidding methods, and timelines that scaled a similar brand.</p>
                </div>
              </li>
              <li style="display: flex; gap: 0.75rem; align-items: flex-start;">
                <span style="color: var(--color-accent-cyan); font-weight: bold;">[02]</span>
                <div>
                  <h4 style="font-size: 1.05rem; margin-bottom: 0.15rem;">CAC and ROAS Benchmarks</h4>
                  <p style="color: var(--color-text-muted); font-size: 0.85rem;">Identify standard acquisition and efficiency ratios recorded in your niche during 2026.</p>
                </div>
              </li>
              <li style="display: flex; gap: 0.75rem; align-items: flex-start;">
                <span style="color: var(--color-accent-cyan); font-weight: bold;">[03]</span>
                <div>
                  <h4 style="font-size: 1.05rem; margin-bottom: 0.15rem;">Live Campaign Diagnostics</h4>
                  <p style="color: var(--color-text-muted); font-size: 0.85rem;">A brief checkup of your active ad sets or marketplace listings to estimate potential savings.</p>
                </div>
              </li>
            </ul>
          </div>
          
          <div style="background: rgba(255,255,255,0.02); border: 1px solid var(--border-light); border-radius: 16px; padding: 2.5rem; text-align: center;">
            <h4 style="font-size: 1.25rem; margin-bottom: 1.5rem; font-family: var(--font-heading);">Schedule Session</h4>
            <p style="color: var(--color-text-muted); font-size: 0.95rem; margin-bottom: 2rem;">Select slot on our live team calendar</p>
            <div style="display: flex; flex-direction: column; gap: 1rem;">
              <a href="https://wa.me/919424995426" class="btn btn-primary" style="font-size: 0.9rem;">💬 WhatsApp Direct booking</a>
              <a href="mailto:connect@marketops.in" class="btn btn-secondary" style="font-size: 0.9rem;">📧 Email: connect@marketops.in</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script define:vars={{ caseStudies }}>
  document.addEventListener('DOMContentLoaded', () => {
    // Pagination Logic
    let currentlyVisible = 12;
    const cards = document.querySelectorAll('.cs-card-item');
    const loadMoreBtn = document.getElementById('btn-load-more');
    const loadInfo = document.getElementById('load-count-info');
    
    function updateVisibility() {
      let visibleCount = 0;
      cards.forEach((card, index) => {
        if (index < currentlyVisible) {
          card.style.display = 'flex';
          card.style.cursor = 'pointer';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });
      loadInfo.innerText = `Showing ${visibleCount} of ${caseStudies.length} case studies`;
      if (currentlyVisible >= caseStudies.length) {
        loadMoreBtn.style.display = 'none';
      }
    }
    
    if(loadMoreBtn) {
      loadMoreBtn.addEventListener('click', () => {
        currentlyVisible += 12;
        updateVisibility();
      });
    }
    
    // Initial setup
    updateVisibility();
    
    // Modal Interaction Logic
    const modal = document.getElementById('caseModal');
    const modalBackdrop = document.getElementById('caseModalBackdrop');
    const modalClose = document.getElementById('caseModalClose');
    const modalContent = document.getElementById('caseModalContent');
    
    function closeModal() {
      modal.classList.remove('active');
      document.body.style.overflow = 'auto'; // restore scrolling
    }
    
    if(modalClose) modalClose.addEventListener('click', closeModal);
    if(modalBackdrop) modalBackdrop.addEventListener('click', closeModal);
    
    cards.forEach(card => {
      card.addEventListener('click', () => {
        const id = card.getAttribute('data-id');
        const cs = caseStudies.find(c => c.id === id);
        if (cs) {
          // Build rich dynamic content for the "Big Page" Modal
          modalContent.innerHTML = `
            <div style="text-align: center; margin-bottom: 2rem;">
              <div class="cs-logo-wrapper" style="height: 60px; margin-bottom: 2rem; display: inline-block;">
                <img src="${cs.img}" alt="${cs.title}" style="height: 100%; filter: brightness(0) invert(1); opacity: 0.9;" />
              </div>
              <br/>
              <span class="cs-tag" style="font-size: 1rem; padding: 0.5rem 1.5rem;">${cs.tag}</span>
              <h2 style="font-size: clamp(2rem, 5vw, 3.5rem); margin: 1.5rem 0; color: #fff; font-family: var(--font-heading);">${cs.title}</h2>
              <p style="font-size: 1.2rem; color: #a0aec0; max-width: 800px; margin: 0 auto; line-height: 1.6;">${cs.desc}</p>
            </div>
            
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2rem; margin: 4rem 0; padding: 3rem; background: rgba(0, 198, 255, 0.05); border: 1px solid rgba(0, 198, 255, 0.2); border-radius: 24px; box-shadow: 0 20px 40px rgba(0,0,0,0.2) inset;">
              ${cs.metrics.map(m => `
                <div style="text-align: center;">
                  <div style="font-size: 3.5rem; font-weight: 900; background: linear-gradient(to right, #00c6ff, #0072ff); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 0.5rem;">${m.val}</div>
                  <div style="font-size: 1.1rem; color: #fff; text-transform: uppercase; letter-spacing: 1.5px; font-weight: 600;">${m.label}</div>
                </div>
              `).join('')}
            </div>
            
            <div style="max-width: 800px; margin: 0 auto;">
              <h3 style="font-size: 2rem; color: #fff; margin-bottom: 1rem; border-bottom: 2px solid rgba(255,255,255,0.1); padding-bottom: 0.5rem;">The Challenge</h3>
              <p style="color: #a0aec0; font-size: 1.15rem; line-height: 1.8;">When ${cs.title.split(' ')[0]} partnered with MarketOps, they were experiencing a severe revenue plateau. Acquisition costs on Meta and Google were rising by 30% YoY, and their existing ad strategies were failing to capture high-LTV customers in competitive global markets.</p>
              
              <h3 style="font-size: 2rem; color: #fff; margin-top: 3rem; margin-bottom: 1rem; border-bottom: 2px solid rgba(255,255,255,0.1); padding-bottom: 0.5rem;">Our Execution Strategy</h3>
              <p style="color: #a0aec0; font-size: 1.15rem; line-height: 1.8;">We audited their entire tracking pixel and rebuilt the funnel from scratch. By implementing advanced server-side API tracking, deploying high-converting UGC creative hooks, and launching aggressive retargeting cycles, we fed algorithmically pure data back to the ad networks.</p>
              
              <div style="background: rgba(255,255,255,0.03); border-radius: 16px; padding: 2rem; margin-top: 3rem; text-align: center; border: 1px dashed rgba(255,255,255,0.2);">
                <p style="font-size: 1.25rem; color: #fff; font-weight: 600; margin-bottom: 1.5rem;">Ready to replicate these metrics for your brand?</p>
                <a href="/contact" class="btn btn-primary" style="font-size: 1.1rem; padding: 1rem 2.5rem; display: inline-block;">Get a Free Account Audit</a>
              </div>
            </div>
          `;
          
          modal.classList.add('active');
          document.body.style.overflow = 'hidden'; // prevent background scrolling
        }
      });
    });
  });
</script>

<style>
  /* Premium Case Study Modal Styles */
  .case-modal {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    z-index: 99999;
    display: none; /* hidden by default */
    align-items: center;
    justify-content: center;
  }
  
  .case-modal.active {
    display: flex;
  }
  
  .case-modal-backdrop {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(5, 8, 15, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }
  
  .case-modal-window {
    position: relative;
    width: 95%;
    max-width: 1100px;
    height: 90vh;
    background: linear-gradient(160deg, #12182b, #0a0d16);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 24px;
    z-index: 1;
    overflow-y: auto;
    padding: 5rem 4rem;
    box-shadow: 0 40px 100px rgba(0,0,0,0.8), inset 0 0 40px rgba(0,198,255,0.05);
    animation: modalPop 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
  }
  
  @keyframes modalPop {
    0% { opacity: 0; transform: scale(0.95) translateY(30px); }
    100% { opacity: 1; transform: scale(1) translateY(0); }
  }
  
  .case-modal-close {
    position: absolute;
    top: 1.5rem; right: 1.5rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #fff;
    width: 50px; height: 50px;
    border-radius: 50%;
    font-size: 2rem;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.3s ease;
    z-index: 10;
  }
  
  .case-modal-close:hover {
    background: rgba(255, 63, 108, 0.8);
    border-color: rgba(255, 63, 108, 1);
    transform: rotate(90deg);
  }
  
  /* Custom Scrollbar for Modal */
  .case-modal-window::-webkit-scrollbar {
    width: 10px;
  }
  .case-modal-window::-webkit-scrollbar-track {
    background: rgba(0,0,0,0.2);
    border-radius: 10px;
  }
  .case-modal-window::-webkit-scrollbar-thumb {
    background: rgba(255,255,255,0.2);
    border-radius: 10px;
  }
  
  @media (max-width: 768px) {
    .case-modal-window {
      padding: 3rem 1.5rem;
      height: 95vh;
      width: 98%;
    }
  }
  /* Premium Case Study Card Styles for Dedicated Page */
  .cs-card {
    background: linear-gradient(145deg, rgba(20, 25, 40, 0.8), rgba(10, 15, 25, 0.95));
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 24px;
    padding: 2.5rem;
    position: relative;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    display: flex;
    flex-direction: column;
  }
  
  .cs-card:hover {
    transform: translateY(-8px);
    border-color: rgba(0, 198, 255, 0.3);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 0 0 30px rgba(0, 198, 255, 0.1);
  }
  
  .cs-card::before {
    content: '';
    position: absolute;
    top: -50%; left: -50%;
    width: 200%; height: 200%;
    background: radial-gradient(circle, rgba(0, 198, 255, 0.08) 0%, transparent 50%);
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }
  
  .cs-card:hover::before {
    opacity: 1;
  }
  
  .cs-logo-wrapper {
    height: 35px;
    margin-bottom: 2rem;
  }
  
  .cs-logo-wrapper img {
    height: 100%;
    object-fit: contain;
    filter: brightness(0) invert(1);
    opacity: 0.8;
    transition: opacity 0.3s ease;
  }
  
  .cs-card:hover .cs-logo-wrapper img {
    opacity: 1;
  }
  
  .cs-tag {
    display: inline-block;
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 1.5rem;
    background: rgba(0, 198, 255, 0.1);
    color: #00c6ff;
    border: 1px solid rgba(0, 198, 255, 0.2);
    align-self: flex-start;
  }
  
  .cs-metrics {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 1.5rem;
    margin-top: auto; /* Push to bottom of card */
  }
  
  .cs-metric-val {
    display: block;
    font-size: 2rem;
    font-weight: 800;
    background: linear-gradient(to right, #00c6ff, #0072ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 0.2rem;
    line-height: 1.1;
  }
  
  .cs-metric-label {
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.85rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  /* Basic Search Input Styles from HTML */
  .cases-dashboard-controls {
    background: rgba(15, 20, 35, 0.4);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 16px;
    padding: 1.5rem;
  }
  .controls-top-row {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .search-input-wrapper {
    flex: 1;
    display: flex;
    align-items: center;
    background: rgba(0,0,0,0.3);
    border-radius: 8px;
    padding: 0.5rem 1rem;
    border: 1px solid rgba(255,255,255,0.1);
  }
  .search-input-wrapper svg {
    color: var(--color-text-muted);
    margin-right: 0.5rem;
