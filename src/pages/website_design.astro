---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Website &amp; Developments | MarketOps" description="Custom web design and scalable development. We build WooCommerce stores, custom Shopify setups, corporate portals, and dynamic databases with AWS infrastructure.">
  <!-- HERO SECTION -->
  <section class="hero-wrapper">
    <div class="hero-overlay" style="background: linear-gradient(180deg, rgba(11, 15, 25, 0.4) 0%, var(--bg-main) 100%);"></div>
    <div class="container" style="position: relative; z-index: 1; text-align: center;">
      <div class="reveal-on-scroll">
        <div class="badge-lead">Custom Web Development</div>
        <h1 class="gradient-text" style="font-size: clamp(2.2rem, 6vw, 4.2rem); max-width: 950px; margin: 0 auto 1.5rem;">
          Build a Powerful Online Presence with <br><span class="gradient-text-alt" style="font-weight: 800;">Fast, Scalable Custom Websites</span>
        </h1>
        <p style="font-size: clamp(1rem, 2.5vw, 1.25rem); color: var(--color-text-muted); max-width: 700px; margin: 0 auto 2.5rem;">
          Convert random traffic into active brand ambassadors. We develop secure WooCommerce structures, fast Shopify catalogs, corporate portals, and dynamic web applications.
        </p>
        <div style="display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap;">
          <a href="#calendly" class="btn btn-primary">Start Your Project</a>
          <a href="#specializations" class="btn btn-secondary">Explore Website Types</a>
        </div>
      </div>
    </div>
  </section>

  <!-- TECH STACK MARQUEE SECTION -->
  <section class="section-padding" style="background: #0a0d16; border-top: 1px solid var(--border-light); border-bottom: 1px solid var(--border-light); padding: 3rem 0; overflow: hidden;">
    <div class="container">
      <div style="display: flex; flex-direction: column; gap: 2rem; align-items: center; text-align: center;">
        <span style="font-size: 0.9rem; text-transform: uppercase; color: var(--color-accent-cyan); font-weight: bold; letter-spacing: 0.1em;">Our Web Designing Partners</span>
        <div class="marquee-container" style="width: 100%;">
          <div class="marquee-content">
            <div class="marquee-card" style="width: 160px; height: 80px;"><span style="font-weight: 800; font-size: 1.2rem; color: #21759b;">WordPress</span></div>
            <div class="marquee-card" style="width: 160px; height: 80px;"><span style="font-weight: 800; font-size: 1.2rem; color: #95bf47;">Shopify</span></div>
            <div class="marquee-card" style="width: 160px; height: 80px;"><span style="font-weight: 800; font-size: 1.2rem; color: #ff9900;">AWS Hosting</span></div>
            <div class="marquee-card" style="width: 160px; height: 80px;"><span style="font-weight: 800; font-size: 1.1rem; color: var(--color-accent-cyan);">CodeX Dev</span></div>
            <div class="marquee-card" style="width: 160px; height: 80px;"><span style="font-weight: 800; font-size: 1.2rem; color: #61dafb;">React Native</span></div>
            <div class="marquee-card" style="width: 160px; height: 80px;"><span style="font-weight: 800; font-size: 1.2rem; color: #dd0031;">Angular Systems</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SPECIALIZATIONS SECTION -->
  <section id="specializations" class="section-padding" style="background: #0d121f;">
    <div class="container">
      <div class="reveal-on-scroll" style="text-align: center; margin-bottom: 5rem;">
        <div class="badge-lead">Web Architecture</div>
        <h2 style="font-size: clamp(1.8rem, 4vw, 2.8rem); margin-bottom: 1.5rem;">Your Digital Growth Starts with a Custom Website</h2>
        <p style="color: var(--color-text-muted); max-width: 650px; margin: 0 auto;">We develop functional digital ecosystems that mirror your operations. Explore the structures we specialize in:</p>
      </div>

      <div class="grid-3">
        <div class="glass-panel reveal-on-scroll">
          <div style="font-size: 2rem; margin-bottom: 1rem;">🛒</div>
          <h3 style="font-size: 1.2rem; margin-bottom: 0.75rem;">eCommerce Websites</h3>
          <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.6;">
            Online stores for selling products with payment gateway, shopping cart &amp; structured order management features built cleanly.
          </p>
        </div>
        <div class="glass-panel reveal-on-scroll">
          <div style="font-size: 2rem; margin-bottom: 1rem;">🏢</div>
          <h3 style="font-size: 1.2rem; margin-bottom: 0.75rem;">Corporate Business Websites</h3>
          <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.6;">
            Professional websites for companies to showcase services, build authority trust &amp; generate outbound business leads.
          </p>
        </div>
        <div class="glass-panel reveal-on-scroll">
          <div style="font-size: 2rem; margin-bottom: 1rem;">👤</div>
          <h3 style="font-size: 1.2rem; margin-bottom: 0.75rem;">Portfolio Websites</h3>
          <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.6;">
            Personal branding websites for freelancers, creators, agencies &amp; professionals to present capabilities and showcase active work.
          </p>
        </div>
        <div class="glass-panel reveal-on-scroll" style="grid-column: span 1.5;">
          <div style="font-size: 2rem; margin-bottom: 1rem;">⚡</div>
          <h3 style="font-size: 1.2rem; margin-bottom: 0.75rem;">Dynamic Websites</h3>
          <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.6;">
            Interactive websites with real-time updates, secure user logins, customized dashboard interfaces &amp; database integration.
          </p>
        </div>
        <div class="glass-panel reveal-on-scroll" style="grid-column: span 1.5;">
          <div style="font-size: 2rem; margin-bottom: 1rem;">🎯</div>
          <h3 style="font-size: 1.2rem; margin-bottom: 0.75rem;">Landing Page &amp; Lead Gen</h3>
          <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.6;">
            High-converting layouts engineered specifically for paid ads, inbound inquiries, data capture, and tactical campaigns.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES SECTION -->
  <section class="section-padding" style="background: var(--bg-main);">
    <div class="container">
      <div class="reveal-on-scroll" style="text-align: center; margin-bottom: 5rem;">
        <div class="badge-lead">Core Quality</div>
        <h2 style="font-size: clamp(1.8rem, 4vw, 2.8rem); margin-bottom: 1.5rem;">Smart Features Built into Every Website We Create</h2>
        <p style="color: var(--color-text-muted); max-width: 600px; margin: 0 auto;">Every website we create includes premium features to maximize search results and speed performance.</p>
      </div>

      <div class="grid-3">
        <div class="glass-panel reveal-on-scroll">
          <div style="color: var(--color-accent-cyan); font-size: 1.5rem; font-weight: 800; margin-bottom: 0.5rem;">📱 Mobile-Responsive</div>
          <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.6;">
            Fluid grid layouts that scale to fit mobile screens, tablet frames, and wide desktop viewports perfectly.
          </p>
        </div>
        <div class="glass-panel reveal-on-scroll">
          <div style="color: var(--color-accent-cyan); font-size: 1.5rem; font-weight: 800; margin-bottom: 0.5rem;">🚀 Fast Loading Speed</div>
          <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.6;">
            Lightweight, optimized asset rendering yielding peak Core Web Vitals performance and immediate page loads.
          </p>
        </div>
        <div class="glass-panel reveal-on-scroll">
          <div style="color: var(--color-accent-cyan); font-size: 1.5rem; font-weight: 800; margin-bottom: 0.5rem;">🔍 SEO-Friendly Structure</div>
          <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.6;">
            Clean code, semantic H1-H4 hierarchy, schema markup, and metadata ready for Google crawl indexing.
          </p>
        </div>
        <div class="glass-panel reveal-on-scroll">
          <div style="color: var(--color-accent-cyan); font-size: 1.5rem; font-weight: 800; margin-bottom: 0.5rem;">🗺️ Easy Navigation</div>
          <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.6;">
            Simple header links, robust search indexes, and clear footer grids so users find everything seamlessly.
          </p>
        </div>
        <div class="glass-panel reveal-on-scroll">
          <div style="color: var(--color-accent-cyan); font-size: 1.5rem; font-weight: 800; margin-bottom: 0.5rem;">🔒 Secure &amp; Scalable</div>
          <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.6;">
            Robust SSL configuration, strict code injection defense parameters, and scalable modular code logic.
          </p>
        </div>
        <div class="glass-panel reveal-on-scroll">
          <div style="color: var(--color-accent-cyan); font-size: 1.5rem; font-weight: 800; margin-bottom: 0.5rem;">📈 Conversion-Focused</div>
          <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.6;">
            Vibrant action buttons, micro-interactions, trust seals, and clear call-to-actions that drive conversions.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQS SECTION -->
  <section class="section-padding" style="background: #080c14; border-top: 1px solid var(--border-light); border-bottom: 1px solid var(--border-light);">
    <div class="container">
      <div class="reveal-on-scroll" style="text-align: center; margin-bottom: 4rem;">
        <div class="badge-lead">FAQ</div>
        <h2 style="font-size: clamp(1.8rem, 4vw, 2.8rem); margin-bottom: 1rem;">Frequently Asked Questions</h2>
        <p style="color: var(--color-text-muted); max-width: 600px; margin: 0 auto;">Everything you need to know about our custom website design &amp; developments.</p>
      </div>

      <div class="accordion-wrapper reveal-on-scroll">
        <!-- Item 1 -->
        <div class="accordion-item">
          <div class="accordion-header">
            <span class="accordion-title">1. How long does it take to design a website?</span>
            <svg class="accordion-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="accordion-content">
            <p>It depends on the project type—basic websites take a few days, while advanced eCommerce or custom websites may take weeks.</p>
          </div>
        </div>
        <!-- Item 2 -->
        <div class="accordion-item">
          <div class="accordion-header">
            <span class="accordion-title">2. What types of websites do you design?</span>
            <svg class="accordion-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="accordion-content">
            <p>We design static websites, dynamic websites, business websites, portfolio sites, landing pages, and eCommerce stores.</p>
          </div>
        </div>
        <!-- Item 3 -->
        <div class="accordion-item">
          <div class="accordion-header">
            <span class="accordion-title">3. Will my website be mobile-friendly?</span>
            <svg class="accordion-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="accordion-content">
            <p>Yes, all websites are fully responsive and work smoothly on mobile, tablet, and desktop devices.</p>
          </div>
        </div>
        <!-- Item 4 -->
        <div class="accordion-item">
          <div class="accordion-header">
            <span class="accordion-title">4. Do you provide SEO-friendly websites?</span>
            <svg class="accordion-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="accordion-content">
            <p>Yes, we build SEO-optimized websites to help improve your visibility on search engines.</p>
          </div>
        </div>
        <!-- Item 5 -->
        <div class="accordion-item">
          <div class="accordion-header">
            <span class="accordion-title">5. Can I update my website after it is built?</span>
            <svg class="accordion-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="accordion-content">
            <p>Yes, we can integrate CMS platforms so you can easily update content, images, and pages.</p>
          </div>
        </div>
        <!-- Item 6 -->
        <div class="accordion-item">
          <div class="accordion-header">
            <span class="accordion-title">6. How much does website design cost?</span>
            <svg class="accordion-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="accordion-content">
            <p>The cost depends on design complexity, features, and functionality required for your website.</p>
          </div>
        </div>
        <!-- Item 7 -->
        <div class="accordion-item">
          <div class="accordion-header">
            <span class="accordion-title">7. Do you offer eCommerce website development?</span>
            <svg class="accordion-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="accordion-content">
            <p>Yes, we create fully functional eCommerce websites with product listings, cart, and payment integration.</p>
          </div>
        </div>
        <!-- Item 8 -->
        <div class="accordion-item">
          <div class="accordion-header">
            <span class="accordion-title">8. Will my website be secure?</span>
            <svg class="accordion-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="accordion-content">
            <p>Yes, we implement strong security measures including SSL integration and safe coding practices.</p>
          </div>
        </div>
        <!-- Item 9 -->
        <div class="accordion-item">
          <div class="accordion-header">
            <span class="accordion-title">9. Do you provide website maintenance services?</span>
            <svg class="accordion-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="accordion-content">
            <p>Yes, we offer ongoing maintenance, updates, and technical support for smooth website performance.</p>
          </div>
        </div>
        <!-- Item 10 -->
        <div class="accordion-item">
          <div class="accordion-header">
            <span class="accordion-title">10. Can you redesign my existing website?</span>
            <svg class="accordion-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="accordion-content">
            <p>Yes, we can redesign your existing website to improve design, performance, and user experience.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CALENDLY EMBED SECTION -->
  <section id="calendly" class="section-padding" style="background: var(--bg-main);">
    <div class="container">
      <div class="reveal-on-scroll" style="text-align: center; margin-bottom: 4rem;">
        <h2 style="font-size: 2.5rem; margin-bottom: 1rem;">Book a Technical Architecture Audit</h2>
        <p style="color: var(--color-text-muted); max-width: 600px; margin: 0 auto;">Connect with a developer today to review speed scores, security protocols, and conversion mapping.</p>
      </div>
      
      <div class="calendly-section reveal-on-scroll">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; padding: 2rem;">
          <div>
            <h3 style="font-size: 1.8rem; margin-bottom: 1rem;">What We Will Cover:</h3>
            <ul style="list-style: none; display: flex; flex-direction: column; gap: 1.2rem; margin: 2rem 0;">
              <li style="display: flex; gap: 0.75rem; align-items: flex-start;">
                <span style="color: var(--color-accent-cyan); font-weight: bold;">[01]</span>
                <div>
                  <h4 style="font-size: 1.05rem; margin-bottom: 0.15rem;">Core Web Vitals Audit</h4>
                  <p style="color: var(--color-text-muted); font-size: 0.85rem;">Test rendering speed bottlenecks, script loading blocks, and LCP benchmarks.</p>
                </div>
              </li>
              <li style="display: flex; gap: 0.75rem; align-items: flex-start;">
                <span style="color: var(--color-accent-cyan); font-weight: bold;">[02]</span>
                <div>
                  <h4 style="font-size: 1.05rem; margin-bottom: 0.15rem;">UX Friction Review</h4>
                  <p style="color: var(--color-text-muted); font-size: 0.85rem;">Identify elements on mobile and desktop layout configurations that trigger bounce rates.</p>
                </div>
              </li>
              <li style="display: flex; gap: 0.75rem; align-items: flex-start;">
                <span style="color: var(--color-accent-cyan); font-weight: bold;">[03]</span>
                <div>
                  <h4 style="font-size: 1.05rem; margin-bottom: 0.15rem;">Scalability Architecture Proposal</h4>
                  <p style="color: var(--color-text-muted); font-size: 0.85rem;">A custom outline mapping database, CMS integration options, and hosting configurations.</p>
                </div>
              </li>
            </ul>
          </div>
          
          <div style="background: rgba(255,255,255,0.02); border: 1px solid var(--border-light); border-radius: 16px; padding: 2.5rem; text-align: center;">
            <h4 style="font-size: 1.25rem; margin-bottom: 1.5rem; font-family: var(--font-heading);">Schedule Session</h4>
            <p style="color: var(--color-text-muted); font-size: 0.95rem; margin-bottom: 2rem;">Select slot on our live team calendar</p>
            <div style="display: flex; flex-direction: column; gap: 1rem;">
              <a href="https://wa.me/919424995426" class="btn btn-primary" style="font-size: 0.9rem;">💬 WhatsApp Direct booking</a>
              <a href="mailto:connect@marketops.in" class="btn btn-secondary" style="font-size: 0.9rem;">📧 Email: connect@marketops.in</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
