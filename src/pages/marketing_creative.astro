---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Marketing Creative & UGC Services | MarketOps" description="Create marketing that people don't just see — they remember. High-converting UGC, performance ad creatives, branding, and motion graphics optimized for conversions.">
  <!-- HERO SECTION -->
  <section class="hero-wrapper">
    <div class="hero-overlay" style="background: linear-gradient(180deg, rgba(11, 15, 25, 0.4) 0%, var(--bg-main) 100%);"></div>
    <div class="container" style="position: relative; z-index: 1; text-align: center;">
      <div class="reveal-on-scroll">
        <div class="badge-lead">Performance Creative Operations</div>
        <h1 class="gradient-text" style="font-size: clamp(2.2rem, 6vw, 4.2rem); max-width: 950px; margin: 0 auto 1.5rem;">
          Create Marketing That People Don’t Just <br><span class="gradient-text-alt" style="font-weight: 800;">See — They Remember</span>
        </h1>
        <p style="font-size: clamp(1rem, 2.5vw, 1.25rem); color: var(--color-text-muted); max-width: 700px; margin: 0 auto 2.5rem;">
          Neuro-aligned ad creatives, engaging UGC videos, and beautiful visual brand assets designed explicitly to drive ROI and lower customer acquisition costs.
        </p>
        <div style="display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap;">
          <a href="#calendly" class="btn btn-primary">Audit Creative Angles</a>
          <a href="#importance" class="btn btn-secondary">Explore Importance</a>
        </div>
      </div>
    </div>
  </section>

  <!-- IMPORTANCE SECTION -->
  <section id="importance" class="section-padding" style="background: #0d121f;">
    <div class="container">
      <div class="reveal-on-scroll" style="text-align: center; margin-bottom: 5rem;">
        <div class="badge-lead">Why Creative Matters</div>
        <h2 style="font-size: clamp(1.8rem, 4vw, 2.8rem); margin-bottom: 1.5rem;">Creativity to Build Powerful Brand Experiences</h2>
      </div>
      <!-- BENTO GRID (Highly Visual & Photorealistic) -->
      <div class="bento-gallery">
        <!-- Item 1: Wide -->
        <div class="bento-item item-wide reveal-on-scroll">
          <div class="bento-graphic" style="background-image: url('/assets/images/attention_creative.webp');"></div>
          <div class="bento-overlay"></div>
          <div class="bento-content">
            <h3 class="bento-title">Grabs Attention Instantly</h3>
            <p class="bento-desc">Strong, vibrant creatives stop users from scrolling and immediately establish authority in highly crowded feeds.</p>
          </div>
        </div>

        <!-- Item 2: Square -->
        <div class="bento-item item-square reveal-on-scroll">
          <div class="bento-graphic" style="background-image: url('/assets/images/value_creative.webp');"></div>
          <div class="bento-overlay"></div>
          <div class="bento-content">
            <h3 class="bento-title">Communicates Value</h3>
            <p class="bento-desc">Layouts simplify complex messaging instantly.</p>
          </div>
        </div>

        <!-- Item 3: Tall -->
        <div class="bento-item item-tall reveal-on-scroll">
          <div class="bento-graphic" style="background-image: url('/assets/images/conversion_creative.webp'); background-position: center;"></div>
          <div class="bento-overlay"></div>
          <div class="bento-content">
            <h3 class="bento-title">Improves Conversion</h3>
            <p class="bento-desc">Well-designed landing page visual hierarchies directly guide purchasing decisions.</p>
          </div>
        </div>

        <!-- Item 4: Square -->
        <div class="bento-item item-square reveal-on-scroll">
          <div class="bento-graphic" style="background-image: url('/assets/images/engagement_creative.webp');"></div>
          <div class="bento-overlay"></div>
          <div class="bento-content">
            <h3 class="bento-title">Boosts Engagement</h3>
            <p class="bento-desc">Vibrant copy and high-fidelity motion elevate shares.</p>
          </div>
        </div>

        <!-- Item 5: Wide -->
        <div class="bento-item item-wide reveal-on-scroll">
          <div class="bento-graphic" style="background-image: url('/assets/images/brand_creative.webp');"></div>
          <div class="bento-overlay"></div>
          <div class="bento-content">
            <h3 class="bento-title">Builds Brand Identity</h3>
            <p class="bento-desc">Consistent visual signatures shape a memorable, highly professional brand image while scaling.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TYPES OF CREATIVE SECTION -->
  <section class="section-padding" style="background: var(--bg-main);">
    <div class="container">
      <div class="reveal-on-scroll" style="text-align: center; margin-bottom: 5rem;">
        <div class="badge-lead">What We Create</div>
        <h2 style="font-size: clamp(1.8rem, 4vw, 2.8rem); margin-bottom: 1.5rem;">Types of Creatives We Produce for Your Brand</h2>
        <p style="color: var(--color-text-muted); max-width: 600px; margin: 0 auto;">From high-converting video formats to flawless marketplace layouts, we cover the full creative spectrum.</p>
      </div>

      <!-- INTERACTIVE HOVER CARDS -->
      <div class="creative-cards-grid">
        <div class="cc-card reveal-on-scroll">
          <div class="cc-bg" style="background-image: url('/assets/images/type_social.webp');"></div>
          <div class="cc-content">
            <h4>Social Media Creatives</h4>
            <p>Engaging grids, carousels, reels covers, and story designs styled perfectly for all social portals.</p>
          </div>
        </div>
        
        <div class="cc-card reveal-on-scroll">
          <div class="cc-bg" style="background-image: url('/assets/images/type_ad.webp');"></div>
          <div class="cc-content">
            <h4>Ad Creatives (Performance)</h4>
            <p>High-converting layouts, text overlays, and multi-version visual assets engineered for Meta & Google Ads.</p>
          </div>
        </div>
        
        <div class="cc-card reveal-on-scroll">
          <div class="cc-bg" style="background-image: url('/assets/images/type_brand.webp');"></div>
          <div class="cc-content">
            <h4>Brand Identity Systems</h4>
            <p>Logos, color schemes, custom typography guides, media kits, and visual corporate specifications.</p>
          </div>
        </div>
        
        <div class="cc-card reveal-on-scroll">
          <div class="cc-bg" style="background-image: url('/assets/images/type_ui.webp');"></div>
          <div class="cc-content">
            <h4>UI & Landing Pages</h4>
            <p>Stunning hero illustrations, customized conversion UI sections, and promotional banners.</p>
          </div>
        </div>
        
        <div class="cc-card reveal-on-scroll">
          <div class="cc-bg" style="background-image: url('/assets/images/type_video.webp');"></div>
          <div class="cc-content">
            <h4>Video & Motion Graphics</h4>
            <p>Animated commercial video cuts, product explainer videos, and optimized vertical ads for TikTok/Shorts.</p>
          </div>
        </div>
        
        <div class="cc-card reveal-on-scroll">
          <div class="cc-bg" style="background-image: url('/assets/images/type_catalog.webp');"></div>
          <div class="cc-content">
            <h4>Marketplace Catalogs</h4>
            <p>High-converting product image grids, A+ content modules, and visual catalog layers that raise sales.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PORTFOLIO BRIEF SHOWCASE -->
  <section class="section-padding" style="background: #080c14; border-top: 1px solid var(--border-light); border-bottom: 1px solid var(--border-light);">
    <div class="container">
      <div class="reveal-on-scroll" style="text-align: center; margin-bottom: 4rem;">
        <div class="badge-lead">Creative Showreel</div>
        <h2 style="font-size: clamp(1.8rem, 4vw, 2.8rem); margin-bottom: 1rem;">Our High-Converting Portfolio</h2>
        <p style="color: var(--color-text-muted); max-width: 600px; margin: 0 auto;">Watch our direct-response video work that captures hooks and keeps users engaged.</p>
      </div>

      <div class="video-section-wrapper reveal-on-scroll" style="max-width: 900px; margin: 0 auto;">
        <video src="assets/home/home.webm" autoplay loop muted playsinline style="width: 100%; border-radius: 16px; border: 1px solid var(--border-light);"></video>
      </div>
    </div>
  </section>

  <!-- FAQS SECTION -->
  <section class="section-padding" style="background: var(--bg-main);">
    <div class="container">
      <div class="reveal-on-scroll" style="text-align: center; margin-bottom: 4rem;">
        <div class="badge-lead">FAQ</div>
        <h2 style="font-size: clamp(1.8rem, 4vw, 2.8rem); margin-bottom: 1rem;">Frequently Asked Questions</h2>
        <p style="color: var(--color-text-muted); max-width: 600px; margin: 0 auto;">Everything you need to know about our Direct Response Creative & UGC solutions.</p>
      </div>

      <div class="accordion-wrapper reveal-on-scroll">
        <!-- Item 1 -->
        <div class="accordion-item">
          <div class="accordion-header">
            <span class="accordion-title">1. What is performance creative and how does it differ from traditional design?</span>
            <svg class="accordion-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="accordion-content">
            <p>Performance creative is designed specifically to drive conversions, sales, and leads on paid ad channels like Meta and Google. It focuses on visual hooks, clear value props, and emotional triggers rather than just looking "pretty".</p>
          </div>
        </div>
        <!-- Item 2 -->
        <div class="accordion-item">
          <div class="accordion-header">
            <span class="accordion-title">2. What formats of marketing creatives do you produce?</span>
            <svg class="accordion-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="accordion-content">
            <p>We produce social media posts, multi-slide carousels, vertical reels/TikTok clips, high-converting performance video ads, UGC styling, brand guidelines, and UI/landing page banners.</p>
          </div>
        </div>
        <!-- Item 3 -->
        <div class="accordion-item">
          <div class="accordion-header">
            <span class="accordion-title">3. How do you ensure creatives stop users from scrolling?</span>
            <svg class="accordion-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="accordion-content">
            <p>We utilize "hook rate optimization" structures where the first 3 seconds of a video or the primary frame of an image feature high-contrast copy, shocking visual transitions, or deep curiosity loops.</p>
          </div>
        </div>
        <!-- Item 4 -->
        <div class="accordion-item">
          <div class="accordion-header">
            <span class="accordion-title">4. Do you provide copywriting and scriptwriting for video ads?</span>
            <svg class="accordion-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="accordion-content">
            <p>Yes, our copywriters handle everything from hooks, body script directions, and visual prompts to final CTAs before production begins.</p>
          </div>
        </div>
        <!-- Item 5 -->
        <div class="accordion-item">
          <div class="accordion-header">
            <span class="accordion-title">5. How many ad creative variations do you deliver?</span>
            <svg class="accordion-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="accordion-content">
            <p>Depending on the package, we deliver multiple hook variations, different aspect ratios (9:16, 1:1, 16:9), and text overlays to let you test what resonates best.</p>
          </div>
        </div>
        <!-- Item 6 -->
        <div class="accordion-item">
          <div class="accordion-header">
            <span class="accordion-title">6. What is UGC (User Generated Content) and why is it important?</span>
            <svg class="accordion-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="accordion-content">
            <p>UGC represents authentic, customer-style video clips. They build immense trust and feel like native organic content rather than annoying direct ads.</p>
          </div>
        </div>
        <!-- Item 7 -->
        <div class="accordion-item">
          <div class="accordion-header">
            <span class="accordion-title">7. Do you create visual assets for Amazon, Flipkart, and other e-commerce marketplaces?</span>
            <svg class="accordion-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="accordion-content">
            <p>Yes, we craft optimized listing product grids, lifestyle images, A+ content modules, and storefront banners tailored to marketplace specs.</p>
          </div>
        </div>
        <!-- Item 8 -->
        <div class="accordion-item">
          <div class="accordion-header">
            <span class="accordion-title">8. Can you design complete brand identity guidelines?</span>
            <svg class="accordion-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="accordion-content">
            <p>Absolutely. We construct logos, custom HSL color palettes, typography rules, brand voices, and comprehensive identity systems.</p>
          </div>
        </div>
        <!-- Item 9 -->
        <div class="accordion-item">
          <div class="accordion-header">
            <span class="accordion-title">9. How do you test and optimize creative performance?</span>
            <svg class="accordion-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="accordion-content">
            <p>We audit raw ad account data to track "Hook Rates" (3-second views/impressions) and "Hold Rates" (15-second views/3-second views) to continually iterate on winning concepts.</p>
          </div>
        </div>
        <!-- Item 10 -->
        <div class="accordion-item">
          <div class="accordion-header">
            <span class="accordion-title">10. Why should we choose MarketOps for our creative operations?</span>
            <svg class="accordion-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="accordion-content">
            <p>We merge beautiful premium design aesthetics with data-driven paid advertising logic, ensuring your creatives look outstanding while driving real sales growth.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CALENDLY EMBED SECTION -->
  <section id="calendly" class="section-padding" style="background: #080c14;">
    <div class="container">
      <div class="reveal-on-scroll" style="text-align: center; margin-bottom: 4rem;">
        <h2 style="font-size: 2.5rem; margin-bottom: 1rem;">Setup Your Free Creative Design Audit</h2>
        <p style="color: var(--color-text-muted); max-width: 600px; margin: 0 auto;">Connect with a performance designer today to evaluate your creative assets and hook ratios.</p>
      </div>
      
      <div class="calendly-section reveal-on-scroll">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; padding: 2rem;">
          <div>
            <h3 style="font-size: 1.8rem; margin-bottom: 1rem;">What We Will Discover:</h3>
            <ul style="list-style: none; display: flex; flex-direction: column; gap: 1.2rem; margin: 2rem 0;">
              <li style="display: flex; gap: 0.75rem; align-items: flex-start;">
                <span style="color: var(--color-accent-cyan); font-weight: bold;">[01]</span>
                <div>
                  <h4 style="font-size: 1.05rem; margin-bottom: 0.15rem;">Creative Angle Gap Analysis</h4>
                  <p style="color: var(--color-text-muted); font-size: 0.85rem;">Discover which psychological triggers and hook types your competitors are using to steal your audience.</p>
                </div>
              </li>
              <li style="display: flex; gap: 0.75rem; align-items: flex-start;">
                <span style="color: var(--color-accent-cyan); font-weight: bold;">[02]</span>
                <div>
                  <h4 style="font-size: 1.05rem; margin-bottom: 0.15rem;">UGC Hook Quality Review</h4>
                  <p style="color: var(--color-text-muted); font-size: 0.85rem;">Audit the first 3 seconds of your active video ads to identify drop-off triggers.</p>
                </div>
              </li>
              <li style="display: flex; gap: 0.75rem; align-items: flex-start;">
                <span style="color: var(--color-accent-cyan); font-weight: bold;">[03]</span>
                <div>
                  <h4 style="font-size: 1.05rem; margin-bottom: 0.15rem;">Visual Consistency Blueprint</h4>
                  <p style="color: var(--color-text-muted); font-size: 0.85rem;">A cohesive layout proposal for social, search display, and e-commerce channel assets.</p>
                </div>
              </li>
            </ul>
          </div>
          
          <div style="background: rgba(255,255,255,0.02); border: 1px solid var(--border-light); border-radius: 16px; padding: 2.5rem; text-align: center;">
            <h4 style="font-size: 1.25rem; margin-bottom: 1.5rem; font-family: var(--font-heading);">Schedule Session</h4>
            <p style="color: var(--color-text-muted); font-size: 0.95rem; margin-bottom: 2rem;">Select slot on our live team calendar</p>
            <div style="display: flex; flex-direction: column; gap: 1rem;">
              <a href="https://wa.me/919424995426" class="btn btn-primary" style="font-size: 0.9rem;">💬 WhatsApp Direct booking</a>
              <a href="mailto:connect@marketops.in" class="btn btn-secondary" style="font-size: 0.9rem;">📧 Email: connect@marketops.in</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* -------------------------------------
     BENTO GALLERY (Premium Asymmetrical Grid)
  -------------------------------------- */
  .bento-gallery {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(2, minmax(280px, auto));
    gap: 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .bento-item {
    position: relative;
    border-radius: 32px;
    background: rgba(20, 25, 45, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.05);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 2.5rem;
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.4s ease;
  }
  
  .bento-item:hover {
    transform: translateY(-10px) scale(1.02);
    box-shadow: 0 30px 60px rgba(0,0,0,0.6);
    border-color: rgba(255,255,255,0.15);
    z-index: 10;
  }
  
  /* Layout Spans */
  .item-wide {
    grid-column: span 2;
  }
  .item-square {
    grid-column: span 1;
  }
  .item-tall {
    grid-column: span 1;
    grid-row: span 2;
  }
  
  @media (max-width: 992px) {
    .bento-gallery {
      grid-template-columns: repeat(2, 1fr);
    }
    .item-tall {
      grid-row: span 1;
    }
  }
  
  @media (max-width: 600px) {
    .bento-gallery {
      grid-template-columns: 1fr;
    }
    .item-wide, .item-square, .item-tall {
      grid-column: span 1;
    }
  }
  
  /* Graphics & Photorealistic Images */
  .bento-graphic {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    z-index: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    transition: transform 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  
  .bento-item:hover .bento-graphic {
    transform: scale(1.08);
  }
  
  .bento-overlay {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: linear-gradient(to top, rgba(10, 15, 25, 1) 0%, rgba(10, 15, 25, 0.6) 50%, rgba(10, 15, 25, 0.1) 100%);
    z-index: 1;
    transition: background 0.4s ease;
  }

  .bento-item:hover .bento-overlay {
    background: linear-gradient(to top, rgba(10, 15, 25, 0.9) 0%, rgba(10, 15, 25, 0.4) 50%, rgba(10, 15, 25, 0.05) 100%);
  }
  
  /* Content Overlay */
  .bento-content {
    position: relative;
    z-index: 2;
  }
  

  .bento-title {
    font-size: 1.8rem;
    font-weight: 800;
    color: #fff;
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }
  
  .bento-desc {
    color: rgba(255,255,255,0.7);
    font-size: 1rem;
    line-height: 1.6;
  }

  /* -------------------------------------
     CREATIVE CARDS GRID (Dynamic Hover)
  -------------------------------------- */
  .creative-cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .cc-card {
    position: relative;
    height: 320px;
    border-radius: 24px;
    overflow: hidden;
    background: #0d121f;
    border: 1px solid rgba(255,255,255,0.05);
    cursor: crosshair;
  }
  
  .cc-bg {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    opacity: 0.5; /* Visible by default */
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    z-index: 0;
  }
  
  .cc-card:hover .cc-bg {
    opacity: 0.9;
    transform: scale(1.1);
  }
  
  .cc-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: linear-gradient(to top, rgba(8, 12, 20, 1) 15%, rgba(8, 12, 20, 0.6) 60%, rgba(8, 12, 20, 0.2) 100%);
    z-index: 1;
    transition: background 0.4s ease;
  }
  
  .cc-card:hover::before {
    background: linear-gradient(to top, rgba(8, 12, 20, 0.95) 20%, rgba(8, 12, 20, 0.5) 65%, rgba(8, 12, 20, 0.1) 100%);
  }
  
  .cc-content {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 2.5rem;
    z-index: 2;
    transition: transform 0.4s ease;
  }
  
  .cc-card:hover .cc-content {
    transform: translateY(-10px);
  }
  
  .cc-icon {
    font-size: 3rem;
    margin-bottom: 1.5rem;
    transform: scale(1);
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  
  .cc-card:hover .cc-icon {
    transform: scale(1.2) rotate(5deg);
  }
  
  .cc-content h4 {
    font-size: 1.5rem;
    color: #fff;
    margin-bottom: 0.5rem;
    font-weight: 700;
  }
  
  .cc-content p {
    color: rgba(255,255,255,0.6);
    font-size: 0.95rem;
    line-height: 1.6;
    opacity: 0;
    max-height: 0;
    overflow: hidden;
    transition: all 0.4s ease;
  }
  
