---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Performance Marketing | MarketOps" description="Scale your business with hyper-targeted paid advertising. We run Google Ads, Meta Ads, LinkedIn Ads, and DSP campaigns with data-driven optimization.">
  <!-- HERO SECTION -->
  <section class="hero-wrapper">
    <video class="hero-video-bg" src="assets/home/home-hero.webm" autoplay loop muted playsinline></video>
    <div class="hero-overlay"></div>
    <div class="container" style="position: relative; z-index: 1; text-align: center;">
      <div class="reveal-on-scroll">
        <div class="badge-lead">Growth Marketing</div>
        <h1 class="gradient-text" style="font-size: clamp(2.2rem, 6vw, 4.2rem); max-width: 900px; margin: 0 auto 1.5rem;">
          Smarter Ads. Better Conversions. <br><span class="gradient-text-alt" style="font-weight: 800;">Bigger Revenue.</span>
        </h1>
        <p style="font-size: clamp(1rem, 2.5vw, 1.25rem); color: var(--color-text-muted); max-width: 700px; margin: 0 auto 2.5rem;">
          Scale your advertising division using algorithmic media buying, secure structures, data analysis, and advanced retargeting strategies.
        </p>
        <div style="display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap;">
          <a href="#calendly" class="btn btn-primary">Scale Campaigns Now</a>
          <a href="#channels" class="btn btn-secondary">Explore Channels</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CHANNELS MARQUEE SECTION -->
  <section class="section-padding" style="background: #0a0d16; border-top: 1px solid var(--border-light); border-bottom: 1px solid var(--border-light); padding: 3rem 0; overflow: hidden;">
    <div class="container">
      <div style="display: flex; flex-direction: column; gap: 2rem; align-items: center; text-align: center;">
        <span style="font-size: 0.9rem; text-transform: uppercase; color: var(--color-accent-cyan); font-weight: bold; letter-spacing: 0.1em;">Our Trusted Performance Marketing Channels</span>
        <div class="marquee-container" style="width: 100%;">
          <div class="marquee-content">
            <div class="marquee-card" style="width: 160px; height: 80px;"><span style="font-weight: 800; font-size: 1.2rem; color: #4285F4;">Google Ads</span></div>
            <div class="marquee-card" style="width: 160px; height: 80px;"><span style="font-weight: 800; font-size: 1.2rem; color: #1877F2;">Meta Ads</span></div>
            <div class="marquee-card" style="width: 160px; height: 80px;"><span style="font-weight: 800; font-size: 1.2rem; color: #0077B5;">LinkedIn</span></div>
            <div class="marquee-card" style="width: 160px; height: 80px;"><span style="font-weight: 800; font-size: 1.1rem; color: var(--color-accent-cyan);">DSP Ads</span></div>
            <div class="marquee-card" style="width: 160px; height: 80px;"><span style="font-weight: 800; font-size: 1.2rem; color: #ff0050;">TikTok Ads</span></div>
            <div class="marquee-card" style="width: 160px; height: 80px;"><span style="font-weight: 800; font-size: 1.2rem; color: #FFFC00; background: #000; padding: 2px 8px; border-radius: 4px;">Snapchat</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY IT MATTERS SECTION -->
  <section id="why-it-matters" class="section-padding" style="background: #0d121f;">
    <div class="container">
      <div class="reveal-on-scroll" style="text-align: center; margin-bottom: 5rem;">
        <div class="badge-lead">Performance Core</div>
        <h2 style="font-size: clamp(1.8rem, 4vw, 2.8rem); margin-bottom: 1.5rem;">Why Performance Marketing Matters for Your Brand</h2>
        <p style="color: var(--color-text-muted); max-width: 650px; margin: 0 auto;">Paid acquisition is the fuel of modern enterprise scaling. Here is what we secure for your brand:</p>
      </div>

      <div class="pm-bento-grid">
        <!-- 1: Brand Awareness (Large) -->
        <div class="pm-bento-item pm-bento-1 reveal-on-scroll">
          <img src="/images/pm_awareness_1780740762130.png" alt="Brand Awareness" class="pm-bento-img" />
          <div class="pm-bento-overlay"></div>
          <div class="pm-bento-content">
            <h3>Increase Brand Awareness</h3>
            <p>Improve your brand visibility through strategic, highly optimized ads on Google, Meta, YouTube &amp; digital marketplaces.</p>
          </div>
        </div>
        
        <!-- 2: Quality Leads -->
        <div class="pm-bento-item pm-bento-2 reveal-on-scroll">
          <img src="/images/pm_leads_1780740774574.png" alt="Quality Leads" class="pm-bento-img" />
          <div class="pm-bento-overlay"></div>
          <div class="pm-bento-content">
            <h3>Quality Leads Generation</h3>
            <p>Connect with high-intent audiences using precise data filters.</p>
          </div>
        </div>

        <!-- 3: Better ROI -->
        <div class="pm-bento-item pm-bento-3 reveal-on-scroll">
          <img src="/images/pm_roi_1780740786974.png" alt="Achieve Better ROI" class="pm-bento-img" />
          <div class="pm-bento-overlay"></div>
          <div class="pm-bento-content">
            <h3>Achieve Better ROI</h3>
            <p>Realize robust efficiency with data-driven localized campaigns.</p>
          </div>
        </div>

        <!-- 4: Expand Reach -->
        <div class="pm-bento-item pm-bento-4 reveal-on-scroll">
          <img src="/images/pm_reach_1780740797806.png" alt="Expand Brand Reach" class="pm-bento-img" />
          <div class="pm-bento-overlay"></div>
          <div class="pm-bento-content">
            <h3>Expand Your Brand Reach</h3>
            <p>Deploy specialized marketing setups constructed to scale across regional, national, and international borders confidently.</p>
          </div>
        </div>

        <!-- 5: Boost Recall -->
        <div class="pm-bento-item pm-bento-5 reveal-on-scroll">
          <img src="/images/pm_recall_1780740810175.png" alt="Boost Recall" class="pm-bento-img" />
          <div class="pm-bento-overlay"></div>
          <div class="pm-bento-content">
            <h3>Boost Audience Recall</h3>
            <p>Cement your message using neuro-focused creatives that elevate customer recognition and brand affinity.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    /* Premium Bento Grid Styles */
    .pm-bento-grid {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      grid-auto-rows: 250px;
      gap: 1.5rem;
      width: 100%;
    }

    .pm-bento-item {
      position: relative;
      border-radius: 20px;
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: #080c14;
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      cursor: pointer;
    }

    .pm-bento-item:hover {
      transform: translateY(-8px);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6), 0 0 20px rgba(0, 198, 255, 0.15);
      border-color: rgba(255, 255, 255, 0.3);
      z-index: 10;
    }

    .pm-bento-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      position: absolute;
      top: 0;
      left: 0;
      transition: transform 0.8s ease, filter 0.8s ease;
      filter: brightness(0.65) contrast(1.1);
    }

    .pm-bento-item:hover .pm-bento-img {
      transform: scale(1.08);
      filter: brightness(0.5) contrast(1.2);
    }

    .pm-bento-overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(to top, rgba(8, 12, 20, 0.95) 0%, rgba(8, 12, 20, 0.4) 60%, transparent 100%);
      pointer-events: none;
    }

    .pm-bento-content {
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      padding: 2rem;
      z-index: 2;
    }

    .pm-bento-content h3 {
      color: #fff;
      font-size: 1.4rem;
      margin-bottom: 0.5rem;
      font-family: var(--font-heading);
      text-shadow: 0 2px 4px rgba(0,0,0,0.8);
      transition: color 0.3s ease;
    }

    .pm-bento-item:hover .pm-bento-content h3 {
      color: var(--color-accent-cyan);
    }

    .pm-bento-content p {
      color: rgba(255, 255, 255, 0.7);
      font-size: 0.95rem;
      line-height: 1.5;
      margin: 0;
      text-shadow: 0 1px 2px rgba(0,0,0,0.8);
    }

    /* Grid layout structure */
    .pm-bento-1 { grid-column: span 4; grid-row: span 2; } 
    .pm-bento-1 h3 { font-size: 2rem; }
    .pm-bento-1 p { font-size: 1.1rem; max-width: 80%; }

    .pm-bento-2 { grid-column: span 2; grid-row: span 1; }
    .pm-bento-3 { grid-column: span 2; grid-row: span 1; }
    .pm-bento-4 { grid-column: span 3; grid-row: span 1; }
    .pm-bento-5 { grid-column: span 3; grid-row: span 1; }

    @media (max-width: 992px) {
      .pm-bento-grid {
        grid-auto-rows: 220px;
      }
      .pm-bento-1 { grid-column: span 6; grid-row: span 2; }
      .pm-bento-2 { grid-column: span 3; grid-row: span 1; }
      .pm-bento-3 { grid-column: span 3; grid-row: span 1; }
      .pm-bento-4 { grid-column: span 6; grid-row: span 1; }
      .pm-bento-5 { grid-column: span 6; grid-row: span 1; }
      .pm-bento-1 p { max-width: 100%; }
    }

    @media (max-width: 600px) {
      .pm-bento-1, .pm-bento-2, .pm-bento-3, .pm-bento-4, .pm-bento-5 {
        grid-column: span 6;
        grid-row: span 1;
      }
    }
  </style>

  <!-- SPECIALIZATIONS SECTION -->
  <section class="section-padding" style="background: var(--bg-main);">
    <div class="container">
      <div class="reveal-on-scroll" style="text-align: center; margin-bottom: 5rem;">
        <div class="badge-lead">Campaign Focus</div>
        <h2 style="font-size: clamp(1.8rem, 4vw, 2.8rem); margin-bottom: 1.5rem;">Hyper-Targeted Campaigns for Real Results</h2>
        <p style="color: var(--color-text-muted); max-width: 600px; margin: 0 auto;">We design, deploy, and scale specific campaign models tailored to your product pipeline.</p>
      </div>

      <div class="grid-3">
        <div class="glass-panel reveal-on-scroll">
          <h4 style="font-size: 1.20rem; margin-bottom: 0.5rem; color: var(--color-accent-cyan);">Search Advertising</h4>
          <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.6;">
            Appear at the absolute top of search results when active buyers query for your industry solutions.
          </p>
        </div>
        <div class="glass-panel reveal-on-scroll">
          <h4 style="font-size: 1.20rem; margin-bottom: 0.5rem; color: var(--color-accent-cyan);">Social Media Advertising</h4>
          <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.6;">
            High-converting creative funnels built across Meta, Instagram, Facebook, and LinkedIn profiles.
          </p>
        </div>
        <div class="glass-panel reveal-on-scroll">
          <h4 style="font-size: 1.20rem; margin-bottom: 0.5rem; color: var(--color-accent-cyan);">Shopping Ads</h4>
          <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.6;">
            Showcase product catalogs directly in front of buyers with fully optimized merchant configurations.
          </p>
        </div>
        <div class="glass-panel reveal-on-scroll">
          <h4 style="font-size: 1.20rem; margin-bottom: 0.5rem; color: var(--color-accent-cyan);">Display Advertising</h4>
          <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.6;">
            Drive consistent awareness with beautifully styled visual layouts and banners across major global websites and apps.
          </p>
        </div>
        <div class="glass-panel reveal-on-scroll">
          <h4 style="font-size: 1.20rem; margin-bottom: 0.5rem; color: var(--color-accent-cyan);">Video Advertising</h4>
          <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.6;">
            Capture intense buyer attention with short-form and long-form video placements on YouTube and high-impact channels.
          </p>
        </div>
        <div class="glass-panel reveal-on-scroll">
          <h4 style="font-size: 1.20rem; margin-bottom: 0.5rem; color: var(--color-accent-cyan);">Remarketing Ads</h4>
          <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.6;">
            Deploy custom dynamic retargeting segments to convert prior visitors who didn't finalize orders or submit contact info.
          </p>
        </div>
        <div class="glass-panel reveal-on-scroll">
          <h4 style="font-size: 1.20rem; margin-bottom: 0.5rem; color: var(--color-accent-cyan);">Marketplace Advertising</h4>
          <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.6;">
            Maximize store margins using targeted PPC options directly inside Amazon, Flipkart, and leading local channels.
          </p>
        </div>
        <div class="glass-panel reveal-on-scroll">
          <h4 style="font-size: 1.20rem; margin-bottom: 0.5rem; color: var(--color-accent-cyan);">Lead Generation</h4>
          <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.6;">
            Harvest qualified operational and enterprise client profiles using highly verified landing page structures.
          </p>
        </div>
        <div class="glass-panel reveal-on-scroll">
          <h4 style="font-size: 1.20rem; margin-bottom: 0.5rem; color: var(--color-accent-cyan);">App Install Campaigns</h4>
          <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.6;">
            Drive highly active users and compound registration volumes for iOS and Android application platforms.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQS SECTION -->
  <section class="section-padding" style="background: #080c14; border-top: 1px solid var(--border-light); border-bottom: 1px solid var(--border-light);">
    <div class="container">
      <div class="reveal-on-scroll" style="text-align: center; margin-bottom: 4rem;">
        <div class="badge-lead">FAQ</div>
        <h2 style="font-size: clamp(1.8rem, 4vw, 2.8rem); margin-bottom: 1rem;">Frequently Asked Questions</h2>
        <p style="color: var(--color-text-muted); max-width: 600px; margin: 0 auto;">Everything you need to know about our Performance Marketing solutions.</p>
      </div>

      <div class="accordion-wrapper reveal-on-scroll">
        <!-- Item 1 -->
        <div class="accordion-item">
          <div class="accordion-header">
            <span class="accordion-title">1. What is Performance Marketing?</span>
            <svg class="accordion-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="accordion-content">
            <p>Performance marketing is a digital marketing strategy where businesses pay based on measurable results like clicks, leads, or sales.</p>
          </div>
        </div>
        <!-- Item 2 -->
        <div class="accordion-item">
          <div class="accordion-header">
            <span class="accordion-title">2. Which Platforms Do You Run Performance Marketing Ads On?</span>
            <svg class="accordion-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="accordion-content">
            <p>We run campaigns on Google Ads, Meta Ads, Instagram, YouTube, LinkedIn, Amazon, Flipkart, and other marketplaces.</p>
          </div>
        </div>
        <!-- Item 3 -->
        <div class="accordion-item">
          <div class="accordion-header">
            <span class="accordion-title">3. How Does Performance Marketing Help My Business?</span>
            <svg class="accordion-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="accordion-content">
            <p>It helps increase brand visibility, generate quality leads, boost sales, and improve overall return on investment (ROI).</p>
          </div>
        </div>
        <!-- Item 4 -->
        <div class="accordion-item">
          <div class="accordion-header">
            <span class="accordion-title">4. What Types of Ads Do You Run?</span>
            <svg class="accordion-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="accordion-content">
            <p>We run Search Ads, Display Ads, Shopping Ads, Video Ads, Remarketing Ads, Lead Generation Ads, and Marketplace Ads.</p>
          </div>
        </div>
        <!-- Item 5 -->
        <div class="accordion-item">
          <div class="accordion-header">
            <span class="accordion-title">5. How Much Budget Is Required for Performance Marketing?</span>
            <svg class="accordion-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="accordion-content">
            <p>The budget depends on your business goals, industry competition, target audience, and advertising platforms.</p>
          </div>
        </div>
        <!-- Item 6 -->
        <div class="accordion-item">
          <div class="accordion-header">
            <span class="accordion-title">6. Can You Target Specific Locations?</span>
            <svg class="accordion-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="accordion-content">
            <p>Yes, we run local, national, international, and customized geo-targeted marketing campaigns.</p>
          </div>
        </div>
        <!-- Item 7 -->
        <div class="accordion-item">
          <div class="accordion-header">
            <span class="accordion-title">7. How Do You Measure Campaign Performance?</span>
            <svg class="accordion-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="accordion-content">
            <p>We track impressions, clicks, conversions, leads, sales, ROAS, CTR, and customer engagement using analytics tools.</p>
          </div>
        </div>
        <!-- Item 8 -->
        <div class="accordion-item">
          <div class="accordion-header">
            <span class="accordion-title">8. How Long Does It Take to See Results?</span>
            <svg class="accordion-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="accordion-content">
            <p>Some campaigns generate results within days, while optimized long-term campaigns deliver stronger growth over time.</p>
          </div>
        </div>
        <!-- Item 9 -->
        <div class="accordion-item">
          <div class="accordion-header">
            <span class="accordion-title">9. Do You Provide Custom Marketing Strategies?</span>
            <svg class="accordion-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="accordion-content">
            <p>Yes, we create customized performance marketing strategies based on your brand goals and target audience.</p>
          </div>
        </div>
        <!-- Item 10 -->
        <div class="accordion-item">
          <div class="accordion-header">
            <span class="accordion-title">10. Why Choose Your Performance Marketing Services?</span>
            <svg class="accordion-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="accordion-content">
            <p>We focus on data-driven strategies, audience targeting, conversion optimization, and scalable business growth.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CALENDLY EMBED SECTION -->
  <section id="calendly" class="section-padding" style="background: var(--bg-main);">
    <div class="container">
      <div class="reveal-on-scroll" style="text-align: center; margin-bottom: 4rem;">
        <h2 style="font-size: 2.5rem; margin-bottom: 1rem;">Setup Your Free Paid Ads Audit</h2>
        <p style="color: var(--color-text-muted); max-width: 600px; margin: 0 auto;">Connect with a media buying specialist today to review targeting leaks and scale budget safely.</p>
      </div>
      
      <div class="calendly-section reveal-on-scroll">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; padding: 2rem;">
          <div>
            <h3 style="font-size: 1.8rem; margin-bottom: 1rem;">What We Will Review:</h3>
            <ul style="list-style: none; display: flex; flex-direction: column; gap: 1.2rem; margin: 2rem 0;">
              <li style="display: flex; gap: 0.75rem; align-items: flex-start;">
                <span style="color: var(--color-accent-cyan); font-weight: bold;">[01]</span>
                <div>
                  <h4 style="font-size: 1.05rem; margin-bottom: 0.15rem;">Audience Filtering Review</h4>
                  <p style="color: var(--color-text-muted); font-size: 0.85rem;">Check if your active pixels and conversion values are feeding clean feedback to Google & Meta.</p>
                </div>
              </li>
              <li style="display: flex; gap: 0.75rem; align-items: flex-start;">
                <span style="color: var(--color-accent-cyan); font-weight: bold;">[02]</span>
                <div>
                  <h4 style="font-size: 1.05rem; margin-bottom: 0.15rem;">Ad Creative Angles Scan</h4>
                  <p style="color: var(--color-text-muted); font-size: 0.85rem;">Identify fatigue rates on hooks, body arguments, and overlays across high-volume campaigns.</p>
                </div>
              </li>
              <li style="display: flex; gap: 0.75rem; align-items: flex-start;">
                <span style="color: var(--color-accent-cyan); font-weight: bold;">[03]</span>
                <div>
                  <h4 style="font-size: 1.05rem; margin-bottom: 0.15rem;">Scale Guard Proposal</h4>
                  <p style="color: var(--color-text-muted); font-size: 0.85rem;">A structured horizontal and vertical budget blueprint built to double spend levels safely.</p>
                </div>
              </li>
            </ul>
          </div>
          
          <div style="background: rgba(255,255,255,0.02); border: 1px solid var(--border-light); border-radius: 16px; padding: 2.5rem; text-align: center;">
            <h4 style="font-size: 1.25rem; margin-bottom: 1.5rem; font-family: var(--font-heading);">Schedule Session</h4>
            <p style="color: var(--color-text-muted); font-size: 0.95rem; margin-bottom: 2rem;">Select slot on our live team calendar</p>
            <div style="display: flex; flex-direction: column; gap: 1rem;">
              <a href="https://wa.me/919424995426" class="btn btn-primary" style="font-size: 0.9rem;">💬 WhatsApp Direct booking</a>
              <a href="mailto:connect@marketops.in" class="btn btn-secondary" style="font-size: 0.9rem;">📧 Email: connect@marketops.in</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
