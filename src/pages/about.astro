---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Us | MarketOps" description="Learn about MarketOps Marketing Solutions, a performance-focused agency helping brands scale profitably with consistent, data-driven systems.">
  <!-- HERO ABOUT -->
  <section class="hero-wrapper" style="min-height: 55vh; padding-top: 8rem;">
    <div class="container" style="position: relative; z-index: 1; text-align: center;">
      <div class="reveal-on-scroll">
        <div class="badge-lead">Company Overview</div>
        <h1 class="gradient-text" style="font-size: clamp(2rem, 5.5vw, 4.2rem); max-width: 850px; margin: 0 auto 1.5rem; text-transform: capitalize;">
          About Us<br><span class="gradient-text-alt" style="font-weight: 800;">MarketOps Marketing Solutions</span>
        </h1>
        <p style="font-size: 1.25rem; color: var(--color-text-muted); max-width: 800px; margin: 0 auto 2.5rem; line-height: 1.7;">
          MarketOps Marketing Solutions is a performance-focused marketing agency dedicated to helping brands scale profitably across digital and e-commerce ecosystems.
        </p>
      </div>
    </div>
  </section>

  <!-- WHO WE ARE SECTION -->
  <section class="section-padding" style="background: #080c14; border-top: 1px solid var(--border-light);">
    <div class="container">
      <div style="display: grid; grid-template-columns: 1fr 1.2fr; gap: 4rem; align-items: center;">
        <div class="reveal-on-scroll">
          <div class="badge-lead">Driven by Performance</div>
          <h2 class="gradient-text" style="font-size: clamp(1.8rem, 3.5vw, 2.6rem); margin-bottom: 1.5rem; line-height: 1.3; font-weight: 800;">
            Driven by performance.<br>Powered by consistency.<br><span class="gradient-text-alt">Focused on your growth.</span>
          </h2>
        </div>
        <div class="reveal-on-scroll" style="display: flex; flex-direction: column; gap: 1.5rem; color: var(--color-text-muted); font-size: 1.05rem; line-height: 1.7;">
          <p>
            We specialize in delivering result-oriented marketing solutions across major channels including Meta Ads, Google Ads, and e-commerce marketplaces such as Amazon, Flipkart, Myntra, and other leading platforms. Our expertise supports brands at every level—local, national, and international markets.
          </p>
          <p>
            Our core focus is simple: consistent performance and measurable growth. We combine data-driven strategies, creative execution, and continuous optimization to ensure every campaign delivers real business outcomes, not just visibility.
          </p>
          <p>
            At MarketOps, we don’t just run campaigns—we build scalable growth systems that help brands increase sales, improve ROI, and expand into new markets with confidence.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- COUNTER METRICS SECTION -->
  <section class="section-padding" style="background: #05070a; border-top: 1px solid var(--border-light); border-bottom: 1px solid var(--border-light);">
    <div class="container">
      <div class="counter-grid">
        <div class="counter-card reveal-on-scroll">
          <div class="counter-number gradient-text" data-target="500" data-suffix="+">0</div>
          <div class="counter-label">Active Clients</div>
        </div>
        <div class="counter-card reveal-on-scroll">
          <div class="counter-number gradient-text" data-target="6" data-prefix="$" data-suffix="M+">0</div>
          <div class="counter-label">Monthly Ad Spend</div>
        </div>
        <div class="counter-card reveal-on-scroll">
          <div class="counter-number gradient-text" data-target="1000" data-suffix="+">0</div>
          <div class="counter-label">Case Studies</div>
        </div>
        <div class="counter-card reveal-on-scroll">
          <div class="counter-number gradient-text" data-target="100" data-suffix="+">0</div>
          <div class="counter-label">Globally Launched Brands</div>
        </div>
      </div>
    </div>
  </section>

  <!-- WE 100% FOCUS ON -->
  <section class="section-padding" style="background: var(--bg-main);">
    <div class="container">
      <div class="reveal-on-scroll" style="text-align: center; margin-bottom: 4rem;">
        <div class="badge-lead">Core Commitments</div>
        <h2 style="font-size: clamp(1.8rem, 4vw, 2.8rem); margin-bottom: 1rem;">We 100% Focus on</h2>
        <p style="color: var(--color-text-muted); max-width: 600px; margin: 0 auto;">Our growth operations are strictly aligned across three core pillars.</p>
      </div>
      
      <div class="grid-3" style="align-items: stretch;">
        <div class="glass-panel reveal-on-scroll" style="display: flex; flex-direction: column; padding: 2.2rem;">
          <h3 style="font-size: 1.4rem; margin-bottom: 1.5rem; color: var(--color-accent-cyan); display: flex; align-items: center; gap: 0.5rem;">
            <span>👥</span> For Clients
          </h3>
          <ul style="list-style: none; display: flex; flex-direction: column; gap: 0.8rem; margin: 0; padding: 0; color: var(--color-text-muted); font-size: 0.95rem;">
            <li style="display: flex; gap: 0.6rem; align-items: flex-start;"><span style="color: var(--color-accent-cyan);">✔</span> Result-Oriented Growth</li>
            <li style="display: flex; gap: 0.6rem; align-items: flex-start;"><span style="color: var(--color-accent-cyan);">✔</span> Strong Brand Presence</li>
            <li style="display: flex; gap: 0.6rem; align-items: flex-start;"><span style="color: var(--color-accent-cyan);">✔</span> Higher ROI &amp; Sales</li>
            <li style="display: flex; gap: 0.6rem; align-items: flex-start;"><span style="color: var(--color-accent-cyan);">✔</span> Long-Term Business Success</li>
            <li style="display: flex; gap: 0.6rem; align-items: flex-start;"><span style="color: var(--color-accent-cyan);">✔</span> Transparent Communication</li>
            <li style="display: flex; gap: 0.6rem; align-items: flex-start;"><span style="color: var(--color-accent-cyan);">✔</span> Data-Driven Marketing Strategies</li>
            <li style="display: flex; gap: 0.6rem; align-items: flex-start;"><span style="color: var(--color-accent-cyan);">✔</span> Consistent Performance Improvement</li>
          </ul>
        </div>
        
        <div class="glass-panel reveal-on-scroll" style="display: flex; flex-direction: column; padding: 2.2rem;">
          <h3 style="font-size: 1.4rem; margin-bottom: 1.5rem; color: var(--color-accent-cyan); display: flex; align-items: center; gap: 0.5rem;">
            <span>🚀</span> For Our Team
          </h3>
          <ul style="list-style: none; display: flex; flex-direction: column; gap: 0.8rem; margin: 0; padding: 0; color: var(--color-text-muted); font-size: 0.95rem;">
            <li style="display: flex; gap: 0.6rem; align-items: flex-start;"><span style="color: var(--color-accent-cyan);">✔</span> Creative &amp; Innovative Thinking</li>
            <li style="display: flex; gap: 0.6rem; align-items: flex-start;"><span style="color: var(--color-accent-cyan);">✔</span> Continuous Learning &amp; Skill Development</li>
            <li style="display: flex; gap: 0.6rem; align-items: flex-start;"><span style="color: var(--color-accent-cyan);">✔</span> Healthy Work Culture</li>
            <li style="display: flex; gap: 0.6rem; align-items: flex-start;"><span style="color: var(--color-accent-cyan);">✔</span> Team Collaboration &amp; Leadership</li>
            <li style="display: flex; gap: 0.6rem; align-items: flex-start;"><span style="color: var(--color-accent-cyan);">✔</span> Performance &amp; Accountability</li>
            <li style="display: flex; gap: 0.6rem; align-items: flex-start;"><span style="color: var(--color-accent-cyan);">✔</span> Growth Opportunities</li>
            <li style="display: flex; gap: 0.6rem; align-items: flex-start;"><span style="color: var(--color-accent-cyan);">✔</span> Work With Passion &amp; Purpose</li>
          </ul>
        </div>
        
        <div class="glass-panel reveal-on-scroll" style="display: flex; flex-direction: column; padding: 2.2rem;">
          <h3 style="font-size: 1.4rem; margin-bottom: 1.5rem; color: var(--color-accent-cyan); display: flex; align-items: center; gap: 0.5rem;">
            <span>📈</span> For Business Growth
          </h3>
          <ul style="list-style: none; display: flex; flex-direction: column; gap: 0.8rem; margin: 0; padding: 0; color: var(--color-text-muted); font-size: 0.95rem;">
            <li style="display: flex; gap: 0.6rem; align-items: flex-start;"><span style="color: var(--color-accent-cyan);">✔</span> Building Long-Term Partnerships</li>
            <li style="display: flex; gap: 0.6rem; align-items: flex-start;"><span style="color: var(--color-accent-cyan);">✔</span> Scaling Brands Globally</li>
            <li style="display: flex; gap: 0.6rem; align-items: flex-start;"><span style="color: var(--color-accent-cyan);">✔</span> Adapting to Market Trends</li>
            <li style="display: flex; gap: 0.6rem; align-items: flex-start;"><span style="color: var(--color-accent-cyan);">✔</span> Delivering Consistent Value</li>
            <li style="display: flex; gap: 0.6rem; align-items: flex-start;"><span style="color: var(--color-accent-cyan);">✔</span> Creating Sustainable Marketing Systems</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- PRESS & LEADERSHIP SHOWCASE -->
  <section class="section-padding" style="background: #080c14; border-top: 1px solid var(--border-light);">
    <div class="container">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;">
        <div class="reveal-on-scroll">
          <div class="badge-lead">As seen in Press Release</div>
          <h2 style="font-size: clamp(1.8rem, 3.5vw, 2.6rem); margin-bottom: 1.5rem; line-height: 1.3;">
            Media Mentions &amp;<br><span class="gradient-text-alt">Industry Authority</span>
          </h2>
          <p style="color: var(--color-text-muted); font-size: 1rem; margin-bottom: 2rem;">
            MarketOps is recognized globally across leading marketing publications and media networks for setting new benchmarks in performance marketing and cross-border ecommerce expansions.
          </p>
          <div style="display: flex; flex-wrap: wrap; gap: 1.5rem; align-items: center; opacity: 0.7;">
            <span style="font-size: 1.1rem; font-weight: 800; color: var(--color-text-white); border: 1px solid var(--border-light); padding: 0.4rem 1rem; border-radius: 6px; background: rgba(255,255,255,0.02);">Forbes</span>
            <span style="font-size: 1.1rem; font-weight: 800; color: var(--color-text-white); border: 1px solid var(--border-light); padding: 0.4rem 1rem; border-radius: 6px; background: rgba(255,255,255,0.02);">Bloomberg</span>
            <span style="font-size: 1.1rem; font-weight: 800; color: var(--color-text-white); border: 1px solid var(--border-light); padding: 0.4rem 1rem; border-radius: 6px; background: rgba(255,255,255,0.02);">Business Insider</span>
            <span style="font-size: 1.1rem; font-weight: 800; color: var(--color-text-white); border: 1px solid var(--border-light); padding: 0.4rem 1rem; border-radius: 6px; background: rgba(255,255,255,0.02);">Yahoo Finance</span>
          </div>
        </div>
        
        <div class="reveal-on-scroll" style="display: flex; justify-content: center;">
          <div class="glass-panel" style="text-align: center; width: 100%; max-width: 480px; padding: 1.5rem;">
            <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=800&q=80" alt="MarketOps leadership team and press operations" style="width: 100%; border-radius: 12px; margin-bottom: 1.5rem; border: 1px solid var(--border-light); aspect-ratio: 16/10; object-fit: cover;">
            <h4 style="font-size: 1.25rem; margin-bottom: 0.35rem;">MarketOps Board &amp; Strategy Leads</h4>
            <p style="color: var(--color-text-muted); font-size: 0.9rem;">Directing global channels, e-commerce growth systems, and performance creative pipelines.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
