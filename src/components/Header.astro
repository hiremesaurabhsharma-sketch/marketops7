<style>
  .mobile-service-link {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.6rem;
    border-radius: 12px;
    font-size: 0.95rem;
    color: rgba(255,255,255,0.85);
    text-decoration: none;
    transition: all 0.3s ease;
  }
  .mobile-service-link:hover {
    background: rgba(255,255,255,0.05);
    color: #fff;
    transform: translateX(5px);
  }
  .mobile-service-link .mobile-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: rgba(255,255,255,0.05);
    box-shadow: 0 4px 10px rgba(0,0,0,0.2);
  }
  
  /* Desktop Dropdown Redesign */
  .dropdown-menu-wide {
    background: rgba(11, 15, 25, 0.95) !important;
    backdrop-filter: blur(24px) !important;
    -webkit-backdrop-filter: blur(24px) !important;
    border: 1px solid rgba(255, 255, 255, 0.08) !important;
    border-radius: 20px !important;
    padding: 1.5rem !important;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.6), inset 0 1px 0 rgba(255, 255, 255, 0.1) !important;
  }
  
  .custom-dropdown-item {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 1.25rem;
    border-radius: 16px;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    background: transparent;
    text-decoration: none;
    border: 1px solid transparent;
  }
  
  .custom-dropdown-item:hover {
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.05);
    transform: translateX(8px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  }
  
  .dropdown-icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.05);
    flex-shrink: 0;
    transition: all 0.3s ease;
  }
  
  @keyframes svgFloatGlow {
    0%, 100% { transform: translateY(0) scale(1); filter: drop-shadow(0 0 2px currentColor); }
    50% { transform: translateY(-3px) scale(1.15); filter: drop-shadow(0 0 10px currentColor); }
  }

  .custom-dropdown-item:hover .dropdown-icon-wrapper {
    background: rgba(255, 255, 255, 0.1);
    box-shadow: inset 0 0 12px currentColor, 0 0 25px currentColor;
    border-color: currentColor;
    transform: scale(1.05) rotate(2deg);
  }
  
  .custom-dropdown-item:hover .dropdown-icon-wrapper svg {
    animation: svgFloatGlow 1.5s ease-in-out infinite;
  }
  
  .dropdown-details h4 {
    font-size: 1.05rem;
    color: #fff;
    margin-bottom: 0.25rem;
    font-weight: 600;
  }
  
  .dropdown-details p {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
    margin: 0;
    line-height: 1.4;
  }
  
  .custom-dropdown-item:hover .dropdown-details h4 {
    color: var(--color-accent-cyan);
  }
</style>
